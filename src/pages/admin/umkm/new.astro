---
import AdminLayout from '../../../components/AdminLayout.astro';
const error = Astro.url.searchParams.get('error');
const categories = ['Kuliner', 'Kriya', 'Jasa', 'Hasil Tani'];
---

<AdminLayout title="Tambah UMKM Baru" breadcrumb="UMKM / Tambah Baru">

  {error && (
    <div role="alert" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#FEE2E2; color:#991B1B; border:1px solid #FECACA;">
      Nama dan kategori UMKM wajib diisi.
    </div>
  )}

  <div class="max-w-3xl">
    <h2 class="font-heading font-bold text-xl mb-6" style="color:var(--color-primary);">Tambah UMKM Baru</h2>

    <form method="POST" action="/api/admin/umkm" class="space-y-5">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label for="nama" class="block font-heading font-medium text-sm mb-1.5">
            Nama UMKM <span>*</span> <span class="font-normal text-text-muted">(wajib)</span>
          </label>
          <input type="text" id="nama" name="nama" required
            class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;" />
        </div>
        <div>
          <label for="kategori" class="block font-heading font-medium text-sm mb-1.5">
            Kategori <span>*</span> <span class="font-normal text-text-muted">(wajib)</span>
          </label>
          <select id="kategori" name="kategori" required
            class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;">
            {categories.map(c => <option value={c}>{c}</option>)}
          </select>
        </div>
      </div>

      <div>
        <label for="lokasi" class="block font-heading font-medium text-sm mb-1.5">Lokasi</label>
        <input type="text" id="lokasi" name="lokasi"
          class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border); min-height:44px;" placeholder="cth. Dusun Ciawi, Desa Sindangsari" />
      </div>

      <div>
        <label for="deskripsi_html" class="block font-heading font-medium text-sm mb-1.5">Deskripsi</label>
        <div class="border rounded-t-lg px-2 py-1.5 flex gap-1" style="border-color:var(--color-border); background:#F8FAFC;">
          {['bold','italic'].map(cmd => (
            <button type="button" data-cmd={cmd}
              class="px-2 py-1 text-xs font-heading font-semibold rounded hover:bg-sand cursor-pointer border border-border">
              {cmd === 'bold' ? 'B' : 'I'}
            </button>
          ))}
        </div>
        <div id="editor" contenteditable="true"
          class="w-full min-h-32 border border-t-0 rounded-b-lg px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border);"></div>
        <input type="hidden" id="deskripsi_html" name="deskripsi_html" />
      </div>

      <fieldset class="border border-border rounded-xl p-4">
        <legend class="font-heading font-semibold text-sm px-2" style="color:var(--color-primary);">Identitas Digital</legend>
        <p class="text-xs text-text-muted mb-4">Isi hanya jika UMKM ini sudah punya akun/tautan yang aktif. Kolom kosong tidak akan ditampilkan di situs.</p>
        <div class="space-y-4">
          {[
            { id:'wa_number',      label:'Nomor WhatsApp', type:'tel',  placeholder:'cth. 6281234567890' },
            { id:'telepon',        label:'Telepon',         type:'tel',  placeholder:'cth. 026200000' },
            { id:'google_maps_url',label:'URL Google Maps', type:'url',  placeholder:'https://maps.google.com/...' },
            { id:'toko_online_url',label:'URL Toko Online', type:'url',  placeholder:'https://tokopedia.com/...' },
          ].map(({ id, label, type, placeholder }) => (
            <div>
              <label for={id} class="block font-heading font-medium text-sm mb-1">{label}</label>
              <input type={type} id={id} name={id}
                class="w-full rounded-lg border px-4 py-2.5 text-base focus:outline-none"
                style="border-color:var(--color-border); min-height:44px;"
                placeholder={placeholder} />
            </div>
          ))}
        </div>
      </fieldset>

      <div>
        <label for="status" class="block font-heading font-medium text-sm mb-1.5">Status</label>
        <select id="status" name="status"
          class="rounded-lg border px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border); min-height:44px; min-width:160px;">
          <option value="draft">Draf</option>
          <option value="published">Terbitkan</option>
        </select>
      </div>

      <div class="sticky bottom-0 bg-white border-t border-border -mx-4 md:-mx-6 px-4 md:px-6 py-3 flex justify-end gap-3" style="box-shadow:0 -2px 8px rgba(0,0,0,.06);">
        <a href="/admin/umkm"
          class="px-4 py-2 rounded-lg font-heading font-medium text-sm border hover:bg-sand"
          style="border-color:var(--color-border); min-height:44px; display:flex; align-items:center;">
          Batal
        </a>
        <button type="submit"
          class="px-5 py-2 rounded-lg font-heading font-semibold text-white text-sm cursor-pointer"
          style="background:var(--color-cta); min-height:44px;">
          Simpan
        </button>
      </div>
    </form>
  </div>

</AdminLayout>

<script>
  const editor = document.getElementById('editor') as HTMLDivElement;
  const hidden = document.getElementById('deskripsi_html') as HTMLInputElement;
  document.querySelector('form')?.addEventListener('submit', () => { hidden.value = editor.innerHTML; });
  document.querySelectorAll('[data-cmd]').forEach(btn => {
    btn.addEventListener('click', () => { editor.focus(); document.execCommand((btn as HTMLElement).dataset.cmd ?? '', false); });
  });
</script>
