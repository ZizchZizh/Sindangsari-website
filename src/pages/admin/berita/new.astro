---
import AdminLayout from '../../../components/AdminLayout.astro';
import MediaInput from '../../../components/MediaInput.astro';
const errors = Astro.url.searchParams.get('errors')?.split(',') ?? [];
---

<AdminLayout title="Tulis Berita Baru" breadcrumb="Berita / Tulis Baru">

  {errors.length > 0 && (
    <div role="alert" class="mb-4 p-4 rounded-lg text-sm" style="background:#FEE2E2; color:#991B1B; border:1px solid #FECACA;">
      <p class="font-heading font-semibold mb-1">Berita belum bisa diterbitkan:</p>
      <ul class="list-disc list-inside space-y-0.5">
        {errors.map(e => <li>{decodeURIComponent(e)}</li>)}
      </ul>
    </div>
  )}

  <div class="max-w-3xl">
    <form id="berita-form" method="POST" action="/api/admin/berita" class="space-y-5">

      <div>
        <div class="flex items-start justify-between mb-1.5">
          <label for="judul" class="font-heading font-medium text-sm">
            Judul Berita <span>*</span> <span class="font-normal text-text-muted">(wajib)</span>
          </label>
          <span class="text-xs text-text-muted italic">Draf tersimpan otomatis</span>
        </div>
        <input type="text" id="judul" name="judul" required
          class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border); min-height:44px;"
          placeholder="Judul singkat dan jelas" />
        <p id="judul-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Judul belum diisi.</p>
      </div>

      <MediaInput />

      <div>
        <label class="block font-heading font-medium text-sm mb-1.5">
          Isi Berita <span>*</span> <span class="font-normal text-text-muted">(wajib)</span>
        </label>
        <div class="border rounded-t-lg px-2 py-1.5 flex gap-1 flex-wrap" style="border-color:var(--color-border); background:#F8FAFC;">
          {[
            ['bold','B','tebal'],['italic','I','miring'],['underline','U','garis bawah'],
          ].map(([cmd, lbl, title]) => (
            <button type="button" data-cmd={cmd}
              class="px-2 py-1 text-xs font-heading font-semibold rounded hover:bg-sand cursor-pointer border border-border"
              title={title}>{lbl}</button>
          ))}
          <span class="w-px bg-border mx-1"></span>
          {[
            ['insertUnorderedList','Daftar •'],['insertOrderedList','Daftar 1.'],['formatBlock-h2','Sub-judul'],
          ].map(([cmd, lbl]) => (
            <button type="button" data-cmd={cmd}
              class="px-2 py-1 text-xs font-heading rounded hover:bg-sand cursor-pointer border border-border">
              {lbl}
            </button>
          ))}
        </div>
        <div id="editor-isi" contenteditable="true"
          class="w-full min-h-64 border border-t-0 rounded-b-lg px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border);"
          aria-label="Isi berita" role="textbox" aria-multiline="true"></div>
        <input type="hidden" id="content_html" name="content_html" />
        <p id="isi-error" class="text-red-600 text-xs mt-1 hidden" role="alert">Isi berita belum diisi.</p>
      </div>

      <input type="hidden" name="_action" id="form-action" value="draft" />

      <!-- Sticky bottom bar -->
      <div class="sticky bottom-0 bg-white border-t border-border -mx-4 md:-mx-6 px-4 md:px-6 py-3 flex justify-end gap-3" style="box-shadow:0 -2px 8px rgba(0,0,0,.06);">
        <a href="/admin/berita"
          class="px-4 py-2 rounded-lg font-heading font-medium text-sm border hover:bg-sand"
          style="border-color:var(--color-border); min-height:44px; display:flex; align-items:center;">
          Batal
        </a>
        <button type="button" id="btn-draft"
          class="px-4 py-2 rounded-lg font-heading font-medium text-sm border cursor-pointer hover:bg-sand"
          style="border-color:var(--color-primary); color:var(--color-primary); min-height:44px;">
          Simpan Draf
        </button>
        <button type="button" id="btn-publish"
          class="px-5 py-2 rounded-lg font-heading font-semibold text-white text-sm cursor-pointer"
          style="background:var(--color-cta); min-height:44px;">
          Terbitkan
        </button>
      </div>
    </form>
  </div>

</AdminLayout>

<style>
  #editor-isi h2 { font-size:1.125rem; font-weight:700; margin:1rem 0 .25rem; }
  #editor-isi ul { list-style:disc; padding-left:1.5rem; }
  #editor-isi ol { list-style:decimal; padding-left:1.5rem; }
</style>

<script>
  const form = document.getElementById('berita-form') as HTMLFormElement;
  const editor = document.getElementById('editor-isi') as HTMLDivElement;
  const hidden = document.getElementById('content_html') as HTMLInputElement;
  const actionInput = document.getElementById('form-action') as HTMLInputElement;

  document.querySelectorAll('[data-cmd]').forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = (btn as HTMLElement).dataset.cmd ?? '';
      editor.focus();
      if (cmd.startsWith('formatBlock-')) document.execCommand('formatBlock', false, cmd.split('-')[1]);
      else document.execCommand(cmd, false);
    });
  });

  function validateAndSubmit(action: string) {
    const judul = (document.getElementById('judul') as HTMLInputElement).value.trim();
    const isi = editor.innerText.trim();
    hidden.value = editor.innerHTML;

    let valid = true;
    if (action === 'publish') {
      if (!judul) {
        document.getElementById('judul-error')?.classList.remove('hidden');
        (document.getElementById('judul') as HTMLInputElement).focus();
        valid = false;
      }
      if (!isi) {
        document.getElementById('isi-error')?.classList.remove('hidden');
        if (valid) editor.focus();
        valid = false;
      }
      if (!valid) {
        // Show alert banner
        const existing = document.querySelector('[role="alert"]');
        if (!existing) {
          const div = document.createElement('div');
          div.setAttribute('role', 'alert');
          div.style.cssText = 'background:#FEE2E2;color:#991B1B;border:1px solid #FECACA;';
          div.className = 'mb-4 p-4 rounded-lg text-sm';
          div.innerHTML = '<p class="font-semibold mb-1">Berita belum bisa diterbitkan:</p><ul class="list-disc list-inside"><li>Judul dan isi berita wajib diisi.</li></ul>';
          form.prepend(div);
        }
        return;
      }
    }
    actionInput.value = action;
    // requestSubmit(), bukan submit(): submit() TIDAK memicu event 'submit',
    // sehingga penjaga "tunggu unggahan foto selesai" di MediaInput terlewat.
    form.requestSubmit();
  }

  document.getElementById('btn-draft')?.addEventListener('click', () => {
    hidden.value = editor.innerHTML;
    actionInput.value = 'draft';
    form.requestSubmit();
  });
  document.getElementById('btn-publish')?.addEventListener('click', () => validateAndSubmit('publish'));
</script>
