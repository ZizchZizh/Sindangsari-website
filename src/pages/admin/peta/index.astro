---
import AdminLayout from '../../../components/AdminLayout.astro';
import { getAllTitikPeta } from '../../../lib/db/titik-peta';

import { getEnv } from '@lib/env';
const env = getEnv();
const titikList = env ? await getAllTitikPeta(env.DB) : [];
const saved = Astro.url.searchParams.get('saved');
const deleted = Astro.url.searchParams.get('deleted');
const titikJson = JSON.stringify(titikList);
---

<AdminLayout title="Kelola Peta" breadcrumb="Peta">

  {saved && (
    <div role="status" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#D1FAE5; color:#065F46; border:1px solid #6EE7B7;">
      Titik peta berhasil disimpan.
    </div>
  )}
  {deleted && (
    <div role="status" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#D1FAE5; color:#065F46; border:1px solid #6EE7B7;">
      Titik peta berhasil dihapus.
    </div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Map picker -->
    <div>
      <h2 class="font-heading font-bold text-xl mb-4" style="color:var(--color-primary);">Peta Titik Lokasi</h2>
      <div id="admin-map" class="w-full rounded-xl border border-border overflow-hidden" style="height:400px;"></div>
      <p class="text-xs text-text-muted mt-2">Klik peta untuk mengisi koordinat secara otomatis.</p>
    </div>

    <!-- Add form -->
    <div>
      <h3 class="font-heading font-semibold text-lg mb-4" style="color:var(--color-primary);">Tambah Titik Peta</h3>
      <form method="POST" action="/api/admin/peta" class="space-y-4">
        <div>
          <label for="label" class="block font-heading font-medium text-sm mb-1.5">Label</label>
          <input type="text" id="label" name="label"
            class="w-full rounded-lg border px-4 py-2.5 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;" placeholder="cth. Curug Masigit" />
        </div>
        <div>
          <label for="jenis" class="block font-heading font-medium text-sm mb-1.5">Jenis <span>*</span></label>
          <select id="jenis" name="jenis" required
            class="w-full rounded-lg border px-4 py-2.5 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;">
            <option value="wisata">Wisata</option>
            <option value="umkm">UMKM</option>
            <option value="potensi">Potensi</option>
          </select>
        </div>
        <div>
          <label for="linked_slug" class="block font-heading font-medium text-sm mb-1.5">Slug Entitas <span>*</span></label>
          <input type="text" id="linked_slug" name="linked_slug" required
            class="w-full rounded-lg border px-4 py-2.5 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;" placeholder="cth. curug-masigit" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="lat" class="block font-heading font-medium text-sm mb-1.5">Lintang <span>*</span></label>
            <input type="number" id="lat" name="lat" step="any" required
              class="w-full rounded-lg border px-4 py-2.5 text-base focus:outline-none"
              style="border-color:var(--color-border); min-height:44px;" placeholder="-6.7022" />
          </div>
          <div>
            <label for="lng" class="block font-heading font-medium text-sm mb-1.5">Bujur <span>*</span></label>
            <input type="number" id="lng" name="lng" step="any" required
              class="w-full rounded-lg border px-4 py-2.5 text-base focus:outline-none"
              style="border-color:var(--color-border); min-height:44px;" placeholder="107.7414" />
          </div>
        </div>
        <button type="submit"
          class="w-full rounded-lg font-heading font-semibold text-white py-2.5 cursor-pointer"
          style="background:var(--color-cta); min-height:44px;">
          Simpan Titik Peta
        </button>
      </form>
    </div>
  </div>

  <!-- Existing pins list -->
  <div class="mt-8 bg-white rounded-xl border border-border overflow-hidden" style="box-shadow:var(--shadow-sm);">
    <table class="w-full text-sm">
      <thead style="background:#F8FAFC;">
        <tr class="border-b border-border">
          <th class="text-left px-4 py-3 font-heading font-semibold">Label</th>
          <th class="text-left px-4 py-3 font-heading font-semibold">Jenis</th>
          <th class="text-left px-4 py-3 font-heading font-semibold hidden md:table-cell">Slug</th>
          <th class="text-left px-4 py-3 font-heading font-semibold hidden md:table-cell">Koordinat</th>
          <th class="px-4 py-3 font-heading font-semibold">Aksi</th>
        </tr>
      </thead>
      <tbody>
        {titikList.length === 0 ? (
          <tr><td colspan="5" class="px-4 py-8 text-center text-text-muted">Belum ada titik peta.</td></tr>
        ) : titikList.map(t => (
          <tr class="border-b border-border last:border-0 hover:bg-sand/30">
            <td class="px-4 py-3 font-medium">{t.label ?? '—'}</td>
            <td class="px-4 py-3">
              <span class:list={['inline-flex px-2 py-0.5 rounded-full text-xs font-medium',
                t.jenis === 'wisata'  ? 'bg-teal-100 text-teal-700' :
                t.jenis === 'umkm'   ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700']}>
                {t.jenis}
              </span>
            </td>
            <td class="px-4 py-3 text-text-muted hidden md:table-cell">{t.linked_slug}</td>
            <td class="px-4 py-3 text-text-muted hidden md:table-cell text-xs">{t.lat.toFixed(4)}, {t.lng.toFixed(4)}</td>
            <td class="px-4 py-3">
              <form method="POST" action="/api/admin/peta/delete"
                onsubmit="return confirm('Hapus titik peta ini?')">
                <input type="hidden" name="id" value={String(t.id)} />
                <button type="submit"
                  class="px-3 py-1.5 rounded-md text-xs font-heading font-medium border cursor-pointer hover:bg-red-50 hover:text-red-600"
                  style="border-color:#FECACA; color:#DC2626;">
                  Hapus
                </button>
              </form>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

</AdminLayout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/I/E=" crossorigin=""></script>

<script define:vars={{ titikJson }}>
  const titiks = JSON.parse(titikJson);
  const map = L.map('admin-map').setView([-6.7022, 107.7414], 14);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors'
  }).addTo(map);

  const colors = { wisata: '#0D9488', umkm: '#15803D', potensi: '#B45309' };
  titiks.forEach(t => {
    const icon = L.circleMarker([t.lat, t.lng], {
      radius: 8, fillColor: colors[t.jenis] ?? '#666', color: '#fff',
      weight: 2, opacity: 1, fillOpacity: 0.9
    }).addTo(map);
    if (t.label) icon.bindPopup(t.label);
  });

  map.on('click', (e) => {
    document.getElementById('lat').value = e.latlng.lat.toFixed(6);
    document.getElementById('lng').value = e.latlng.lng.toFixed(6);
  });
</script>
