---
import AdminLayout from '../../../components/AdminLayout.astro';
import { getDemografiById, totalPenduduk } from '../../../lib/db/demografi';
import { getEnv } from '@lib/env';

const env = getEnv();
const id = Number(Astro.params.id);
const row = env && id ? await getDemografiById(id, env.DB) : null;

if (!row) return Astro.redirect('/admin/demografi');

const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');

const nf = new Intl.NumberFormat('id-ID');
const judul = [row.dusun, row.rw && `RW ${row.rw}`, row.rt && `RT ${row.rt}`].filter(Boolean).join(' · ') || `Data #${row.id}`;
---

<AdminLayout title={`Sunting ${judul}`} breadcrumb="Demografi / Sunting">

  {saved && (
    <div role="status" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#D1FAE5; color:#065F46; border:1px solid #6EE7B7;">
      Perubahan berhasil disimpan.
    </div>
  )}
  {error && (
    <div role="alert" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#FEE2E2; color:#991B1B; border:1px solid #FECACA;">
      Minimal isi salah satu dari Dusun/RW/RT. Angka penduduk & KK harus bilangan bulat ≥ 0.
    </div>
  )}

  <div class="max-w-2xl">
    <div class="flex items-start justify-between gap-4 mb-1">
      <h2 class="font-heading font-bold text-xl" style="color:var(--color-primary);">Sunting Data Demografi</h2>
      <a href="/profil#demografi" target="_blank" rel="noopener"
        class="text-sm font-heading font-medium text-accent hover:underline shrink-0 mt-1">
        Lihat di situs ↗
      </a>
    </div>
    <p class="text-sm text-text-muted mb-6">
      Total penduduk saat ini: <strong style="color:var(--color-primary);">{nf.format(totalPenduduk(row))} jiwa</strong>
      (dihitung otomatis dari L + P).
    </p>

    <form method="POST" action={`/api/admin/demografi/${row.id}`} class="space-y-5">

      <div>
        <label for="dusun" class="block font-heading font-medium text-sm mb-1.5">Dusun</label>
        <input type="text" id="dusun" name="dusun" value={row.dusun}
          class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border); min-height:44px;"
          placeholder="cth. Dusun I / Sindangsari" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="rw" class="block font-heading font-medium text-sm mb-1.5">RW</label>
          <input type="text" id="rw" name="rw" value={row.rw} inputmode="numeric"
            class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;" placeholder="cth. 03" />
        </div>
        <div>
          <label for="rt" class="block font-heading font-medium text-sm mb-1.5">RT</label>
          <input type="text" id="rt" name="rt" value={row.rt} inputmode="numeric"
            class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;" placeholder="cth. 01" />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="laki_laki" class="block font-heading font-medium text-sm mb-1.5">Laki-laki</label>
          <input type="number" id="laki_laki" name="laki_laki" min="0" step="1" value={String(row.laki_laki)}
            class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;" />
        </div>
        <div>
          <label for="perempuan" class="block font-heading font-medium text-sm mb-1.5">Perempuan</label>
          <input type="number" id="perempuan" name="perempuan" min="0" step="1" value={String(row.perempuan)}
            class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;" />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="jumlah_kk" class="block font-heading font-medium text-sm mb-1.5">Jumlah KK</label>
          <input type="number" id="jumlah_kk" name="jumlah_kk" min="0" step="1" value={String(row.jumlah_kk)}
            class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;" />
        </div>
        <div>
          <label for="urutan" class="block font-heading font-medium text-sm mb-1.5">Urutan Tampil</label>
          <input type="number" id="urutan" name="urutan" min="0" step="1" value={String(row.urutan)}
            class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
            style="border-color:var(--color-border); min-height:44px;" />
        </div>
      </div>

      <div class="sticky bottom-0 bg-white border-t border-border -mx-4 md:-mx-6 px-4 md:px-6 py-3 flex justify-end gap-3" style="box-shadow:0 -2px 8px rgba(0,0,0,.06);">
        <a href="/admin/demografi"
          class="px-4 py-2 rounded-lg font-heading font-medium text-sm border hover:bg-sand"
          style="border-color:var(--color-border); min-height:44px; display:flex; align-items:center;">
          Batal
        </a>
        <button type="submit"
          class="px-5 py-2 rounded-lg font-heading font-semibold text-white text-sm cursor-pointer"
          style="background:var(--color-cta); min-height:44px;">
          Simpan Perubahan
        </button>
      </div>

    </form>
  </div>

</AdminLayout>
