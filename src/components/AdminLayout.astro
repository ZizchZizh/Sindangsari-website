---
import '../styles/global.css';

interface Props {
  title: string;
  breadcrumb?: string;
  currentPath?: string;
}

const { title, breadcrumb, currentPath = Astro.url.pathname } = Astro.props;

const menuItems = [
  { href: '/admin/dasbor',    label: 'Dasbor',          icon: 'grid' },
  { href: '/admin/konten',    label: 'Konten Halaman',  icon: 'file-text' },
  { href: '/admin/perangkat', label: 'Perangkat Desa',  icon: 'users' },
  { href: '/admin/layanan',   label: 'Layanan Desa',    icon: 'clipboard-list' },
  { href: '/admin/wisata',    label: 'Wisata',          icon: 'palmtree' },
  { href: '/admin/umkm',      label: 'UMKM',            icon: 'shopping-bag' },
  { href: '/admin/peta',      label: 'Peta',            icon: 'map' },
  { href: '/admin/berita',    label: 'Berita',          icon: 'newspaper' },
  { href: '/admin/media',     label: 'Media',           icon: 'image' },
  { href: '/admin/statistik', label: 'Statistik',       icon: 'bar-chart' },
];

const isActive = (href: string) => currentPath.startsWith(href);
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <title>{title} — Panel Admin Desa Sindangsari</title>
  <meta name="robots" content="noindex,nofollow" />
</head>

<body class="font-body min-h-screen" style="background:#F1F5F9; color:var(--color-text);">

  <!-- ── Sidebar (desktop) ──────────────────────────────── -->
  <aside
    id="admin-sidebar"
    class="fixed top-0 left-0 h-full w-64 z-30 flex flex-col"
    style="background:#14532D; transform:translateX(-100%); transition:transform 200ms ease;"
    aria-label="Sidebar admin"
  >
    <!-- Logo -->
    <a href="/admin/dasbor" class="flex items-center gap-3 px-5 py-5 border-b border-white/10 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent">
      <span class="w-9 h-9 rounded-full bg-accent grid place-items-center font-heading font-bold text-sm text-white shrink-0" aria-hidden="true">DS</span>
      <div class="leading-tight">
        <span class="block font-heading font-bold text-white text-sm">Panel Admin</span>
        <span class="block text-white/60 text-xs">Desa Sindangsari</span>
      </div>
    </a>

    <!-- Menu -->
    <nav aria-label="Menu admin" class="flex flex-col p-3 gap-0.5 flex-1 overflow-y-auto">
      {menuItems.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'flex items-center gap-3 px-3 py-2.5 rounded-md font-heading font-medium text-sm transition-colors duration-150 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent',
            isActive(href)
              ? 'bg-accent text-white'
              : 'text-white/75 hover:bg-white/10 hover:text-white',
          ]}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Keluar -->
    <div class="p-3 border-t border-white/10">
      <form method="POST" action="/api/admin/logout">
        <button
          type="submit"
          class="w-full flex items-center gap-3 px-3 py-2.5 rounded-md font-heading font-medium text-sm text-white/75 hover:bg-white/10 hover:text-white transition-colors duration-150 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent cursor-pointer"
        >
          Keluar
        </button>
      </form>
    </div>
  </aside>

  <!-- ── Backdrop overlay (mobile) ──────────────────────── -->
  <div id="admin-overlay" class="fixed inset-0 bg-black/40 z-20 hidden lg:hidden" aria-hidden="true"></div>

  <!-- ── Main content area ──────────────────────────────── -->
  <div class="lg:pl-64 min-h-screen flex flex-col">

    <!-- Top bar -->
    <header class="sticky top-0 z-10 bg-white border-b border-border flex items-center justify-between px-4 md:px-6 h-14 shrink-0" style="box-shadow:var(--shadow-sm);">
      <div class="flex items-center gap-3">
        <!-- Hamburger (mobile) -->
        <button
          id="admin-hamburger"
          class="lg:hidden w-10 h-10 rounded-md flex items-center justify-center hover:bg-sand transition-colors cursor-pointer focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
          aria-label="Buka menu"
          aria-expanded="false"
          aria-controls="admin-sidebar"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <!-- Breadcrumb -->
        <span class="font-heading font-semibold text-primary text-sm md:text-base">
          {breadcrumb ?? title}
        </span>
      </div>
      <div class="flex items-center gap-3">
        <a
          href="/"
          target="_blank"
          rel="noopener"
          class="text-sm font-heading font-medium text-accent hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent rounded px-1"
        >
          Lihat Situs ↗
        </a>
      </div>
    </header>

    <!-- Page content -->
    <main class="flex-1 p-4 md:p-6">
      <slot />
    </main>

  </div>

</body>

<style>
  @media (min-width: 1024px) {
    #admin-sidebar {
      transform: translateX(0) !important;
    }
  }
  #admin-sidebar.sidebar-open {
    transform: translateX(0) !important;
  }
</style>

<script>
  const sidebar = document.getElementById('admin-sidebar');
  const overlay = document.getElementById('admin-overlay');
  const hamburger = document.getElementById('admin-hamburger');

  function openSidebar() {
    sidebar?.classList.add('sidebar-open');
    overlay?.classList.remove('hidden');
    hamburger?.setAttribute('aria-expanded', 'true');
  }
  function closeSidebar() {
    sidebar?.classList.remove('sidebar-open');
    overlay?.classList.add('hidden');
    hamburger?.setAttribute('aria-expanded', 'false');
  }

  hamburger?.addEventListener('click', openSidebar);
  overlay?.addEventListener('click', closeSidebar);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeSidebar(); });
</script>
</html>
