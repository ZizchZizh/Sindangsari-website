---
import Layout from '../components/Layout.astro';
import { getAllTitikPeta, JENIS_TITIK, JENIS_TITIK_KEYS } from '../lib/db/titik-peta';
import { mediaUrl } from '../lib/db/media';
import batasDesa from '../data/batas-desa-sindangsari.json';
import { getEnv } from '@lib/env';

const env = getEnv();
const titikList = env ? await getAllTitikPeta(env.DB) : [];

// Hitung jumlah titik per jenis untuk badge di panel filter.
const counts: Record<string, number> = Object.fromEntries(JENIS_TITIK_KEYS.map(k => [k, 0]));
for (const t of titikList) counts[t.jenis] = (counts[t.jenis] ?? 0) + 1;

// Panel filter hanya menampilkan jenis yang punya titik, tapi tiga jenis inti
// (wisata/umkm/potensi) selalu tampil agar peta konsisten walau datanya kosong.
const jenisTampil = JENIS_TITIK_KEYS.filter(
  k => counts[k] > 0 || k === 'wisata' || k === 'umkm' || k === 'potensi'
);

// Konfigurasi ringkas (warna + basis tautan) yang diserahkan ke skrip klien.
const clientConfig = Object.fromEntries(
  JENIS_TITIK_KEYS.map(k => [k, {
    color: JENIS_TITIK[k].color,
    link: JENIS_TITIK[k].link,
    label: JENIS_TITIK[k].label,
  }])
);

// Titik yang dialirkan ke klien — hanya field yang dipakai panel detail.
const pts = titikList.map(t => ({
  lat: t.lat,
  lng: t.lng,
  jenis: t.jenis,
  label: t.label,
  linked_slug: t.linked_slug,
  deskripsi: t.deskripsi,
  foto: t.cover_key ? mediaUrl(t.cover_key) : null,
}));

const finalJson = JSON.stringify(pts);
const configJson = JSON.stringify(clientConfig);
const batasJson = JSON.stringify(batasDesa);
---

<Layout
  title="Peta Desa — Desa Sindangsari"
  description="Peta interaktif Desa Sindangsari: titik wisata, UMKM, dan potensi desa. Klik penanda untuk detail."
>

<main id="main" class="mx-auto max-w-[1152px] px-4 sm:px-6 py-6">
  <h1 class="text-2xl sm:text-3xl font-heading font-extrabold text-primary">Peta Desa Sindangsari</h1>
  <p class="text-muted mt-1">Jelajahi titik wisata, UMKM, potensi, dan fasilitas umum desa (tempat ibadah, sekolah, kesehatan, dan lainnya). Klik penanda untuk info.</p>

  <div class="grid lg:grid-cols-[280px_1fr] gap-5 mt-5">
    <!-- Filter panel -->
    <aside class="bg-white border border-line rounded-2xl p-5 h-max shadow-[0_4px_10px_rgba(16,35,26,.08)]">
      <h2 class="font-heading font-semibold text-ink">Tampilkan</h2>
      <div class="space-y-2 mt-3">
        {jenisTampil.map(k => (
          <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-sand cursor-pointer">
            <input type="checkbox" class="filter-check w-4 h-4 rounded text-accent" data-type={k} checked />
            <span class="w-7 h-7 rounded-full grid place-items-center shrink-0" style={`background:${JENIS_TITIK[k].color}; transform:rotate(-45deg);`}>
              <i data-lucide={JENIS_TITIK[k].icon} class="w-3.5 h-3.5 text-white" style="transform:rotate(45deg);"></i>
            </span>
            <span class="font-medium text-sm">{JENIS_TITIK[k].label}</span>
            <span class="ml-auto text-sm text-muted tabular-nums">{counts[k]}</span>
          </label>
        ))}
      </div>
      <hr class="my-3 border-line" />
      <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-sand cursor-pointer">
        <input type="checkbox" id="toggle-batas" class="w-4 h-4 rounded text-accent" checked />
        <span class="w-7 h-0 shrink-0 rounded-full" style="border-top:3px solid #166534;"></span>
        <span class="font-medium text-sm">Batas Wilayah Desa</span>
      </label>
      <hr class="my-4 border-line" />
      <button id="resetView" class="inline-flex items-center gap-2 w-full justify-center border-2 border-primary text-primary font-heading font-semibold py-2.5 rounded-lg hover:bg-primary hover:text-white transition-colors min-h-[44px] text-sm">
        <i data-lucide="locate-fixed" class="w-5 h-5"></i> Pusatkan ke Desa
      </button>
      <p class="text-xs text-muted mt-3 flex items-center gap-1.5">
        <i data-lucide="info" class="w-4 h-4"></i> Peta gratis berbasis OpenStreetMap.
      </p>
      <div class="mt-4 bg-sand/60 border border-line rounded-lg p-3 flex gap-2">
        <i data-lucide="shield-check" class="w-4 h-4 text-primary shrink-0 mt-0.5"></i>
        <p class="text-xs text-muted">
          <span class="font-heading font-semibold text-ink">Pengelola desa</span> dapat menambah, menyunting, atau menghapus titik peta melalui <span class="font-medium text-primary">Panel Admin › Kelola Peta</span>.
        </p>
      </div>
    </aside>

    <!-- Map + panel detail -->
    <div class="relative rounded-2xl overflow-hidden border border-line shadow-[0_4px_12px_rgba(16,35,26,.10)]">
      <div id="peta-map" style="height: min(70vh, 640px); z-index: 0;"></div>

      <!-- Panel detail pin: kanan di desktop, sheet dari bawah di HP -->
      <aside id="pin-panel" class="pin-panel" hidden aria-label="Detail lokasi">
        <button type="button" id="pin-close" class="pin-close" aria-label="Tutup">&times;</button>
        <div id="pin-foto-wrap" class="pin-foto-wrap" hidden>
          <img id="pin-foto" class="pin-foto" src="" alt="" />
        </div>
        <div class="pin-body">
          <span id="pin-kategori" class="pin-kategori">
            <span id="pin-dot" class="pin-dot"></span>
            <span id="pin-kategori-teks"></span>
          </span>
          <h3 id="pin-nama" class="pin-nama"></h3>
          <p id="pin-deskripsi" class="pin-deskripsi"></p>
          <a id="pin-link" class="pin-link" href="#" hidden>Lihat detail →</a>
        </div>
      </aside>
    </div>
  </div>
</main>

</Layout>

<!-- Hash SRI terverifikasi (leaflet 1.9.4). Halaman ini sebelumnya memuat Leaflet
     tanpa proteksi integritas sama sekali. -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script define:vars={{ finalJson, configJson, batasJson }}>
  const CENTER = [-6.7022, 107.7414], ZOOM = 13;
  const map = L.map('peta-map', { scrollWheelZoom: false }).setView(CENTER, ZOOM);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19, attribution: '© OpenStreetMap' }).addTo(map);
  map.on('focus', () => map.scrollWheelZoom.enable());
  map.on('blur', () => map.scrollWheelZoom.disable());

  // ── Batas wilayah desa (dari shapefile resmi Export_Output.shp, WGS84) ──
  const batasLayer = L.geoJSON(JSON.parse(batasJson), {
    style: { color: '#166534', weight: 3, opacity: 0.9, fillColor: '#166534', fillOpacity: 0.06 },
    interactive: false,
  }).addTo(map);
  const BATAS_BOUNDS = batasLayer.getBounds();
  map.fitBounds(BATAS_BOUNDS, { padding: [24, 24] });

  const CFG = JSON.parse(configJson);
  const points = JSON.parse(finalJson);

  // Basis tautan: '/wisata/' (prefix + slug), '/potensi' (datar), '' (tanpa detail).
  const hrefFor = (cfg, slug) => {
    if (!cfg.link) return null;
    return cfg.link.endsWith('/') ? cfg.link + slug : cfg.link;
  };

  // ── Panel detail (kanan di desktop, sheet dari bawah di HP) ──
  const panel = document.getElementById('pin-panel');
  const elFotoWrap = document.getElementById('pin-foto-wrap');
  const elFoto = document.getElementById('pin-foto');
  const elDot = document.getElementById('pin-dot');
  const elKat = document.getElementById('pin-kategori-teks');
  const elNama = document.getElementById('pin-nama');
  const elDesk = document.getElementById('pin-deskripsi');
  const elLink = document.getElementById('pin-link');

  function showPanel(p) {
    const cfg = CFG[p.jenis] || { color: '#666', link: '', label: p.jenis };
    if (p.foto) { elFoto.src = p.foto; elFoto.alt = p.label || ''; elFotoWrap.hidden = false; }
    else { elFoto.removeAttribute('src'); elFotoWrap.hidden = true; }
    elDot.style.background = cfg.color;
    elKat.textContent = cfg.label;
    elNama.textContent = p.label || cfg.label;        // textContent → aman dari XSS
    if (p.deskripsi) { elDesk.textContent = p.deskripsi; elDesk.hidden = false; }
    else { elDesk.hidden = true; }
    const href = hrefFor(cfg, p.linked_slug);
    if (href) { elLink.href = href; elLink.hidden = false; } else { elLink.hidden = true; }
    panel.hidden = false;
  }
  function hidePanel() { panel.hidden = true; }
  document.getElementById('pin-close').addEventListener('click', hidePanel);
  map.on('click', hidePanel); // klik area kosong peta menutup panel

  const layers = {};
  Object.keys(CFG).forEach(k => { layers[k] = L.layerGroup(); });

  points.forEach(p => {
    const cfg = CFG[p.jenis] || { color: '#666', link: '', label: p.jenis };
    const icon = L.divIcon({
      className: '',
      html: `<div style="width:24px;height:24px;background:${cfg.color};border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,.3);"></div>`,
      iconSize: [24, 24],
      iconAnchor: [12, 24],
    });
    if (!layers[p.jenis]) layers[p.jenis] = L.layerGroup();
    L.marker([p.lat, p.lng], { icon, title: p.label })
      .on('click', () => showPanel(p))
      .addTo(layers[p.jenis]);
  });

  Object.values(layers).forEach(l => l.addTo(map));

  document.querySelectorAll('.filter-check').forEach(cb => {
    cb.addEventListener('change', () => {
      const t = cb.dataset.type;
      if (!layers[t]) return;
      cb.checked ? layers[t].addTo(map) : map.removeLayer(layers[t]);
    });
  });

  document.getElementById('resetView').addEventListener('click', () => map.fitBounds(BATAS_BOUNDS, { padding: [24, 24] }));

  // Toggle tampilan garis batas desa.
  document.getElementById('toggle-batas').addEventListener('change', (e) => {
    e.target.checked ? batasLayer.addTo(map) : map.removeLayer(batasLayer);
  });

  setTimeout(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); }, 150);
</script>

<style>
  /* Panel detail pin — kanan (desktop) / sheet dari bawah (HP). */
  .pin-panel {
    position: absolute;
    top: 12px; right: 12px; bottom: 12px;
    width: 320px; max-width: calc(100% - 24px);
    z-index: 500;
    background: #fff;
    border-radius: 16px;
    overflow-y: auto;
    box-shadow: 0 8px 28px rgba(16, 35, 26, .22);
    -webkit-overflow-scrolling: touch;
  }
  .pin-close {
    position: absolute; top: 8px; right: 8px; z-index: 2;
    width: 32px; height: 32px; border-radius: 9999px;
    background: rgba(255,255,255,.92); border: 1px solid #E2E8F0;
    font-size: 20px; line-height: 1; color: #334155; cursor: pointer;
    display: grid; place-items: center;
  }
  .pin-close:hover { background: #fff; color: #0f172a; }
  .pin-foto-wrap { width: 100%; aspect-ratio: 4 / 3; background: #F1F5F9; }
  .pin-foto { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pin-body { padding: 14px 16px 18px; }
  .pin-kategori { display: inline-flex; align-items: center; gap: 6px; font-size: .75rem; font-weight: 600; color: #475569; text-transform: uppercase; letter-spacing: .02em; }
  .pin-dot { width: 10px; height: 10px; border-radius: 9999px; display: inline-block; }
  .pin-nama { font-family: 'Lexend', sans-serif; font-weight: 800; color: #166534; font-size: 1.1rem; line-height: 1.25; margin: .4rem 0 .3rem; }
  .pin-deskripsi { font-size: .9rem; color: #475569; line-height: 1.6; white-space: pre-line; margin: 0; }
  .pin-link { display: inline-block; margin-top: .8rem; color: #059669; font-weight: 600; font-size: .9rem; }
  .pin-link:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .pin-panel {
      top: auto; right: 0; left: 0; bottom: 0;
      width: 100%; max-width: 100%;
      max-height: 64%;
      border-radius: 16px 16px 0 0;
    }
  }
</style>
