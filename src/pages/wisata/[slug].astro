---
import Layout from '../../components/Layout.astro';
import { getWisataBySlug } from '../../lib/db/wisata';
import { getMediaForEntity } from '../../lib/db/media';

const { slug } = Astro.params as { slug: string };
import { getEnv } from '@lib/env';
const env = getEnv();

const wisata = env ? await getWisataBySlug(slug, env.DB) : null;
if (!wisata) return Astro.redirect('/404');

const mediaList = env ? await getMediaForEntity('wisata', wisata.id, env.DB) : [];
const coverImage = mediaList[0];
---

<Layout
  title={`${wisata.nama} — Wisata Desa Sindangsari`}
  description={wisata.deskripsi_html.replace(/<[^>]+>/g, '').slice(0, 160)}
  ogImage={coverImage ? `/api/media/${encodeURIComponent(coverImage.r2_key_display)}` : undefined}
>

  <!-- Header -->
  <div class="py-10 md:py-14" style="background:linear-gradient(135deg,#166534,#14532D);">
    <div class="mx-auto max-w-6xl px-4 md:px-6 text-white">
      <nav aria-label="Breadcrumb" class="text-sm mb-3 opacity-75">
        <a href="/" class="hover:underline">Beranda</a> /
        <a href="/wisata" class="hover:underline">Wisata</a> /
        <span>{wisata.nama}</span>
      </nav>
      <h1 class="font-heading font-bold text-3xl md:text-4xl">{wisata.nama}</h1>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 md:px-6 py-12">

    <!-- Cover image -->
    {coverImage ? (
      <div class="aspect-[16/7] rounded-xl overflow-hidden mb-8 border border-border" style="box-shadow:var(--shadow-md);">
        <img
          src={`/api/media/${encodeURIComponent(coverImage.r2_key_display)}`}
          alt={coverImage.alt}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="aspect-[16/7] rounded-xl overflow-hidden mb-8 flex items-center justify-center" style="background:linear-gradient(135deg,#D1FAE5,#F4EBDD);">
        <span class="font-heading font-bold text-6xl" style="color:var(--color-accent); opacity:.2;">{wisata.nama[0]}</span>
      </div>
    )}

    <!-- Description -->
    <div class="prose max-w-none mb-8" set:html={wisata.deskripsi_html} />

    <!-- Gallery -->
    {mediaList.length > 1 && (
      <div class="mb-8">
        <h2 class="font-heading font-semibold text-xl mb-4" style="color:var(--color-primary);">Galeri Foto</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {mediaList.slice(1).map(m => (
            <div class="aspect-[4/3] rounded-lg overflow-hidden border border-border">
              <img src={`/api/media/${encodeURIComponent(m.r2_key_display)}`} alt={m.alt}
                class="w-full h-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Map link -->
    <div class="bg-white rounded-xl p-4 border border-border flex items-center gap-4" style="box-shadow:var(--shadow-sm);">
      <div class="w-10 h-10 rounded-full grid place-items-center shrink-0" style="background:var(--color-accent);">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
      </div>
      <div>
        <p class="font-heading font-medium text-sm">Lihat di Peta</p>
        <p class="text-text-muted text-xs">Temukan lokasi pada peta interaktif Desa Sindangsari</p>
      </div>
      <a href="/peta" class="ml-auto px-3 py-1.5 rounded-md font-heading font-medium text-sm border transition-colors hover:bg-accent hover:text-white focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent" style="border-color:var(--color-accent); color:var(--color-accent);">
        Lihat di Peta →
      </a>
    </div>

  </div>

</Layout>

<style>
  .prose h2 { font-size:1.25rem; font-weight:700; color:var(--color-primary); margin:1.5rem 0 .5rem; }
  .prose p  { margin:.5rem 0; line-height:1.7; }
</style>
