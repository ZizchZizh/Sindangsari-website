---
import Layout from '../components/Layout.astro';
import { getSection } from '../lib/db/page-section';
import { getAllDemografi, ringkasDemografi, totalPenduduk } from '../lib/db/demografi';
import batasDesa from '../data/batas-desa-sindangsari.json';
import { getEnv } from '@lib/env';

const env = getEnv();
const [umum, geografis, sejarah, demografi] = await Promise.all([
  env ? getSection('profil-umum', env.DB) : null,
  env ? getSection('profil-geografis', env.DB) : null,
  env ? getSection('profil-sejarah', env.DB) : null,
  env ? getAllDemografi(env.DB) : [],
]);

// Demografi: agregat & skala grafik dihitung di server (SSR, tanpa JS klien).
const ringkas = ringkasDemografi(demografi);
const maxTotalRT = Math.max(1, ...demografi.map(totalPenduduk));
const nf = new Intl.NumberFormat('id-ID');
const pct = (n: number, total: number): number => (total > 0 ? Math.round((n / total) * 100) : 0);
// Label ringkas per baris untuk grafik batang, mis. "Dsn I · RW03/RT01".
const labelRT = (r: { dusun: string; rw: string; rt: string }): string => {
  const rwRt = [r.rw && `RW${r.rw}`, r.rt && `RT${r.rt}`].filter(Boolean).join('/');
  return [r.dusun, rwRt].filter(Boolean).join(' · ') || 'Tanpa label';
};
const batasJson = JSON.stringify(batasDesa);
---

<Layout
  title="Profil Desa — Desa Sindangsari"
  description="Profil lengkap Desa Sindangsari: sejarah, kondisi geografis, visi misi, dan gambaran desa dataran tinggi Kecamatan Kasomalang Subang."
>

<!-- Hero -->
<section class="relative">
  <div class="h-48 sm:h-64 overflow-hidden">
    <img
      src="/images/hero_sindangsari.png"
      alt="Alam dan perbukitan Desa Sindangsari"
      class="w-full h-full object-cover"
    />
  </div>
  <div class="absolute inset-0" style="background: rgba(20,83,45,0.6);"></div>
  <div class="absolute inset-0 flex items-end">
    <div class="mx-auto max-w-[1152px] px-4 sm:px-6 w-full pb-6 text-white">
      <nav aria-label="Breadcrumb" class="text-sm text-white/80 flex items-center gap-1.5">
        <a href="/" class="hover:text-white">Beranda</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="font-medium">Profil Desa</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold mt-1">Profil Desa Sindangsari</h1>
      <p class="text-white/85 mt-1 max-w-xl">Kecamatan Kasomalang, Kabupaten Subang, Jawa Barat</p>
    </div>
  </div>
</section>

<!-- Sticky subnav -->
<div class="subnav sticky top-16 z-30 bg-white border-b border-line" style="scroll-behavior:smooth;">
  <div class="mx-auto max-w-[1152px] px-4 sm:px-6 py-2 flex gap-2 overflow-x-auto">
    {[
      ['#umum', 'Umum'],
      ['#geografis', 'Geografis'],
      ['#demografi', 'Demografi'],
      ['#sejarah', 'Sejarah'],
      ['#peta', 'Peta'],
      ['/pemerintahan', 'Pemerintahan ↗'],
    ].map(([href, label]) => (
      <a
        href={href}
        class="whitespace-nowrap px-3 py-1.5 rounded-full text-sm font-heading font-semibold border-2 border-line text-ink hover:border-accent transition-colors"
      >
        {label}
      </a>
    ))}
  </div>
</div>

<main id="main" class="mx-auto max-w-[1152px] px-4 sm:px-6 py-10 space-y-14">

  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    {[
      { icon: 'users', label: 'Penduduk', value: '±7.600', sub: 'Jiwa' },
      { icon: 'layers', label: 'Wilayah', value: '±305', sub: 'Hektar' },
      { icon: 'home', label: 'Dusun', value: '3', sub: 'Wilayah' },
      { icon: 'store', label: 'UMKM', value: '10+', sub: 'Terdaftar' },
    ].map(s => (
      <div class="bg-white border border-line rounded-2xl p-5 shadow-[0_4px_10px_rgba(16,35,26,.08)]">
        <i data-lucide={s.icon} class="w-6 h-6 text-accent"></i>
        <p class="font-heading font-extrabold text-2xl text-primary mt-2">{s.value}</p>
        <p class="text-xs font-heading font-semibold text-muted uppercase mt-0.5">{s.sub}</p>
        <p class="text-sm text-ink mt-0.5">{s.label}</p>
      </div>
    ))}
  </div>

  <!-- Umum -->
  <section id="umum" style="scroll-margin-top: 120px;">
    <h2 class="text-2xl font-heading font-extrabold text-primary">Profil Umum</h2>
    <p class="text-muted mt-2 max-w-3xl leading-relaxed">
      Desa Sindangsari adalah desa dataran tinggi yang terletak di Kecamatan Kasomalang, Kabupaten Subang, Provinsi Jawa Barat. Berada pada ketinggian 500–600 mdpl dengan suhu udara sejuk (15–25°C), desa ini dikenal dengan lahan pertanian yang subur dan potensi ekowisata alam yang menjanjikan.
    </p>
    <div class="prose max-w-none mt-4 text-muted leading-relaxed" set:html={umum?.content_html ?? ''} />
    <div class="grid sm:grid-cols-2 gap-4 mt-6">
      {[
        { label: 'Kecamatan', value: 'Kasomalang' },
        { label: 'Kabupaten', value: 'Subang' },
        { label: 'Provinsi', value: 'Jawa Barat' },
        { label: 'Kode Pos', value: '41289' },
      ].map(row => (
        <div class="flex justify-between py-3 border-b border-line">
          <span class="font-heading font-semibold text-ink">{row.label}</span>
          <span class="text-muted">{row.value}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Geografis -->
  <section id="geografis" style="scroll-margin-top: 120px;">
    <h2 class="text-2xl font-heading font-extrabold text-primary">Kondisi Geografis</h2>
    <p class="text-muted mt-2 max-w-3xl leading-relaxed">
      Secara geografis, Desa Sindangsari berada di koordinat sekitar -6.702° LS, 107.741° BT. Dari luas wilayah 305 ha, sekitar 161 ha berupa sawah, 60 ha pemukiman, dan 46 ha perkebunan. Desa berbatasan dengan Desa Bojongloa di utara, Desa Pasanggrahan di selatan, Desa Darmaga (Kec. Cisalak) di timur, dan Desa Kasomalang Wetan di barat.
    </p>
    <div class="prose max-w-none mt-4 text-muted leading-relaxed" set:html={geografis?.content_html ?? ''} />
    <div class="grid sm:grid-cols-3 gap-4 mt-6">
      {[
        { icon: 'mountain', label: 'Ketinggian', value: '500–600 m dpl' },
        { icon: 'thermometer', label: 'Suhu', value: '15–25°C' },
        { icon: 'tree-pine', label: 'Luas Wilayah', value: '±305 ha' },
      ].map(item => (
        <div class="bg-white border border-line rounded-xl p-5 shadow-[0_4px_10px_rgba(16,35,26,.08)]">
          <i data-lucide={item.icon} class="w-6 h-6 text-accent"></i>
          <p class="text-xs font-heading font-semibold text-muted uppercase mt-2">{item.label}</p>
          <p class="font-heading font-bold text-xl text-primary mt-0.5">{item.value}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Demografi -->
  <section id="demografi" style="scroll-margin-top: 120px;">
    <h2 class="text-2xl font-heading font-extrabold text-primary">Demografi Penduduk</h2>
    <p class="text-muted mt-2 max-w-3xl leading-relaxed">
      Persebaran penduduk Desa Sindangsari berdasarkan data per RT — jumlah jiwa, komposisi jenis
      kelamin, dan jumlah kepala keluarga (KK).
    </p>

    {demografi.length === 0 ? (
      <div class="mt-6 bg-white border border-line rounded-2xl p-8 text-center shadow-[0_4px_10px_rgba(16,35,26,.08)]">
        <i data-lucide="pie-chart" class="w-8 h-8 text-accent mx-auto"></i>
        <p class="font-heading font-semibold text-ink mt-3">Data demografi sedang dilengkapi</p>
        <p class="text-muted text-sm mt-1 max-w-md mx-auto">
          Rincian jumlah penduduk per RT akan segera ditampilkan di sini dalam bentuk grafik dan tabel.
        </p>
      </div>
    ) : (
      <div class="mt-6 space-y-8">

        <!-- Kartu ringkasan -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {[
            { icon: 'users', label: 'Total Penduduk', value: ringkas.totalPenduduk, sub: 'Jiwa' },
            { icon: 'user', label: 'Laki-laki', value: ringkas.totalLaki, sub: `${pct(ringkas.totalLaki, ringkas.totalPenduduk)}%` },
            { icon: 'user', label: 'Perempuan', value: ringkas.totalPerempuan, sub: `${pct(ringkas.totalPerempuan, ringkas.totalPenduduk)}%` },
            { icon: 'home', label: 'Kepala Keluarga', value: ringkas.totalKK, sub: 'KK' },
          ].map(s => (
            <div class="bg-white border border-line rounded-2xl p-5 shadow-[0_4px_10px_rgba(16,35,26,.08)]">
              <i data-lucide={s.icon} class="w-6 h-6 text-accent"></i>
              <p class="font-heading font-extrabold text-2xl text-primary mt-2 tabular-nums">{nf.format(s.value)}</p>
              <p class="text-xs font-heading font-semibold text-muted uppercase mt-0.5">{s.sub}</p>
              <p class="text-sm text-ink mt-0.5">{s.label}</p>
            </div>
          ))}
        </div>

        <!-- Komposisi jenis kelamin -->
        <div class="bg-white border border-line rounded-2xl p-6 shadow-[0_4px_10px_rgba(16,35,26,.08)]">
          <h3 class="font-heading font-bold text-lg text-primary">Komposisi Jenis Kelamin</h3>
          <div class="flex h-8 rounded-full overflow-hidden border border-line mt-4" role="img"
            aria-label={`Laki-laki ${nf.format(ringkas.totalLaki)} jiwa, Perempuan ${nf.format(ringkas.totalPerempuan)} jiwa`}>
            <div style={`width:${pct(ringkas.totalLaki, ringkas.totalPenduduk)}%; background:#166534;`}></div>
            <div class="flex-1" style="background:#D97706;"></div>
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-2 mt-4 text-sm">
            <span class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-sm shrink-0" style="background:#166534;"></span>
              <span class="text-ink">Laki-laki</span>
              <span class="text-muted tabular-nums">{nf.format(ringkas.totalLaki)} · {pct(ringkas.totalLaki, ringkas.totalPenduduk)}%</span>
            </span>
            <span class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-sm shrink-0" style="background:#D97706;"></span>
              <span class="text-ink">Perempuan</span>
              <span class="text-muted tabular-nums">{nf.format(ringkas.totalPerempuan)} · {pct(ringkas.totalPerempuan, ringkas.totalPenduduk)}%</span>
            </span>
          </div>
        </div>

        <!-- Persebaran penduduk per RT -->
        <div class="bg-white border border-line rounded-2xl p-6 shadow-[0_4px_10px_rgba(16,35,26,.08)]">
          <h3 class="font-heading font-bold text-lg text-primary">Persebaran Penduduk per RT</h3>
          <p class="text-sm text-muted mt-1">Jumlah jiwa di tiap RT.</p>
          <div class="mt-5 space-y-3">
            {demografi.map(r => (
              <div class="flex items-center gap-3">
                <div class="w-24 sm:w-44 shrink-0 text-xs sm:text-sm text-ink truncate" title={labelRT(r)}>{labelRT(r)}</div>
                <div class="flex-1 bg-sand rounded-full h-6 overflow-hidden">
                  <div class="h-full rounded-full" style={`width:${Math.max(pct(totalPenduduk(r), maxTotalRT), 4)}%; background:var(--color-accent);`}></div>
                </div>
                <div class="w-14 shrink-0 text-right text-sm font-heading font-bold tabular-nums text-primary">{nf.format(totalPenduduk(r))}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Tabel rinci per RT -->
        <div class="bg-white border border-line rounded-2xl overflow-hidden shadow-[0_4px_10px_rgba(16,35,26,.08)]">
          <div class="px-6 pt-6">
            <h3 class="font-heading font-bold text-lg text-primary">Rincian per RT</h3>
          </div>
          <div class="overflow-x-auto mt-4">
            <table class="w-full text-sm">
              <thead style="background:#F8FAFC;">
                <tr class="border-y border-line text-muted">
                  <th class="text-left px-4 py-3 font-heading font-semibold">Dusun</th>
                  <th class="text-center px-4 py-3 font-heading font-semibold">RW</th>
                  <th class="text-center px-4 py-3 font-heading font-semibold">RT</th>
                  <th class="text-right px-4 py-3 font-heading font-semibold">Laki-laki</th>
                  <th class="text-right px-4 py-3 font-heading font-semibold">Perempuan</th>
                  <th class="text-right px-4 py-3 font-heading font-semibold">Total</th>
                  <th class="text-right px-4 py-3 font-heading font-semibold">KK</th>
                </tr>
              </thead>
              <tbody>
                {demografi.map(r => (
                  <tr class="border-b border-line last:border-0">
                    <td class="px-4 py-3 text-ink">{r.dusun || '—'}</td>
                    <td class="px-4 py-3 text-center text-muted tabular-nums">{r.rw || '—'}</td>
                    <td class="px-4 py-3 text-center text-muted tabular-nums">{r.rt || '—'}</td>
                    <td class="px-4 py-3 text-right tabular-nums">{nf.format(r.laki_laki)}</td>
                    <td class="px-4 py-3 text-right tabular-nums">{nf.format(r.perempuan)}</td>
                    <td class="px-4 py-3 text-right tabular-nums font-semibold text-primary">{nf.format(totalPenduduk(r))}</td>
                    <td class="px-4 py-3 text-right tabular-nums">{nf.format(r.jumlah_kk)}</td>
                  </tr>
                ))}
              </tbody>
              <tfoot>
                <tr class="border-t-2 border-line font-heading font-bold" style="background:#F8FAFC;">
                  <td class="px-4 py-3 text-primary" colspan="3">Total ({nf.format(ringkas.jumlahRT)} RT)</td>
                  <td class="px-4 py-3 text-right tabular-nums text-primary">{nf.format(ringkas.totalLaki)}</td>
                  <td class="px-4 py-3 text-right tabular-nums text-primary">{nf.format(ringkas.totalPerempuan)}</td>
                  <td class="px-4 py-3 text-right tabular-nums text-primary">{nf.format(ringkas.totalPenduduk)}</td>
                  <td class="px-4 py-3 text-right tabular-nums text-primary">{nf.format(ringkas.totalKK)}</td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>

      </div>
    )}
  </section>

  <!-- Sejarah -->
  <section id="sejarah" style="scroll-margin-top: 120px;">
    <h2 class="text-2xl font-heading font-extrabold text-primary">Sejarah Desa</h2>
    <div class="prose max-w-none mt-4 text-muted leading-relaxed" set:html={sejarah?.content_html ?? `
      <p>Nama "Sindangsari" berasal dari bahasa Sunda: <em>Sindang</em> yang berarti "singgah" dan <em>Sari</em> yang berarti "indah/menarik", sehingga bermakna tempat persinggahan yang nyaman dan asri. Desa Sindangsari resmi terbentuk pada tahun 1982 sebagai hasil pemekaran dari Desa Darmaga, Kecamatan Cisalak, yang diprakarsai tokoh masyarakat karena kepadatan penduduk dan jarak antarkampung yang jauh, dengan Bapak Endang Sopandi sebagai penjabat sementara kepala desa pertama.</p>
      <p>Sebelum menjadi desa yang berdiri sendiri, kawasan ini memiliki sejarah panjang yang melibatkan berbagai masa kepemimpinan (Kuwu) sejak awal abad ke-20. Saat ini desa terus berkembang dengan fokus pada pertanian, ekowisata, dan ekonomi kreatif masyarakat.</p>
    `} />
  </section>

  <!-- Peta -->
  <section id="peta" style="scroll-margin-top: 120px;">
    <h2 class="text-2xl font-heading font-extrabold text-primary">Peta Desa</h2>
    <p class="text-muted mt-2">Lokasi Desa Sindangsari di Kecamatan Kasomalang, Kabupaten Subang.</p>
    <div id="profil-map" class="mt-4 rounded-2xl overflow-hidden border border-line shadow-[0_4px_10px_rgba(16,35,26,.08)]" style="height: 380px;"></div>
    <p class="text-sm text-muted mt-2 flex items-center gap-1.5">
      <i data-lucide="info" class="w-4 h-4"></i>
      Koordinat: -6.702, 107.741 ·
      <a href="/peta" class="text-accent hover:underline font-medium">Buka peta interaktif lengkap →</a>
    </p>
  </section>

  <!-- CTA Pemerintahan -->
  <section style="scroll-margin-top: 120px;">
    <div class="bg-primary text-white rounded-2xl p-8 flex flex-col sm:flex-row items-center gap-6">
      <div class="flex-1">
        <h2 class="text-2xl font-heading font-extrabold">Pemerintahan Desa</h2>
        <p class="text-white/80 mt-2">Pelajari struktur organisasi, perangkat desa, visi misi, dan tugas fungsi pemerintahan Desa Sindangsari.</p>
      </div>
      <a href="/pemerintahan" class="inline-flex items-center gap-2 bg-white text-primary font-heading font-semibold px-6 py-3 rounded-lg hover:bg-sand transition-colors min-h-[44px] shrink-0">
        <i data-lucide="landmark" class="w-5 h-5"></i> Lihat Pemerintahan
      </a>
    </div>
  </section>

</main>

</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script define:vars={{ batasJson }}>
  document.addEventListener('DOMContentLoaded', function() {
    var map = L.map('profil-map', { scrollWheelZoom: false }).setView([-6.7022, 107.7414], 14);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
    // Batas wilayah desa dari shapefile resmi (WGS84).
    var batas = L.geoJSON(JSON.parse(batasJson), {
      style: { color: '#166534', weight: 3, opacity: 0.9, fillColor: '#166534', fillOpacity: 0.06 },
      interactive: false
    }).addTo(map);
    map.fitBounds(batas.getBounds(), { padding: [16, 16] });
    L.marker([-6.7022, 107.7414]).addTo(map).bindPopup('<b>Desa Sindangsari</b><br>Kec. Kasomalang, Subang');
    if (typeof lucide !== 'undefined') lucide.createIcons();
  });
  setTimeout(function() {
    if (typeof lucide !== 'undefined') lucide.createIcons();
  }, 300);
</script>

<style>
  .prose p { margin: .5rem 0; line-height: 1.75; }
  .prose h3 { font-family: 'Lexend', sans-serif; font-weight: 700; color: #166534; margin: 1rem 0 .5rem; }
  [id] { scroll-margin-top: 120px; }
</style>
