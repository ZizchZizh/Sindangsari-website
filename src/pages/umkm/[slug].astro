---
import Layout from '../../components/Layout.astro';
import { getUmkmBySlug } from '../../lib/db/umkm';
import { getMediaForEntity, mediaUrl } from '../../lib/db/media';

const { slug } = Astro.params as { slug: string };
import { getEnv } from '@lib/env';
const env = getEnv();

const umkm = env ? await getUmkmBySlug(slug, env.DB) : null;
if (!umkm) return Astro.redirect('/404');

const mediaList = env ? await getMediaForEntity('umkm', umkm.id, env.DB) : [];

// Peta slug lama — hanya untuk data seed yang belum punya foto sampul di DB.
const getUmkmImg = (s: string): string | null => {
  if (s === 'kerupuk-opak-ranginang') return '/images/kerupuk_tradisional.png';
  if (s === 'kopi-aren-kasomalang') return '/images/kopi_aren.png';
  if (s === 'keripik-bonggol-pisang') return '/images/keripik_bonggol.png';
  return null;
};

// Sumber gambar berjenjang: sampul DB → media tertaut → peta slug lama → placeholder huruf.
const linkedCover = umkm.cover_key ? null : mediaList[0];
const coverSrc = umkm.cover_key
  ? mediaUrl(umkm.cover_key)
  : linkedCover
    ? mediaUrl(linkedCover.r2_key_display)
    : getUmkmImg(umkm.slug);
const coverAlt = umkm.cover_alt || linkedCover?.alt || umkm.nama;

// Galeri: media tertaut kecuali yang sudah dipakai sebagai sampul.
const galleryList = (umkm.cover_key
  ? mediaList.filter(m => m.id !== umkm.cover_media_id)
  : mediaList.slice(1)
).slice(0, 6);

const canonicalUrl = new URL(`/umkm/${slug}`, Astro.site ?? 'https://sindangsari.web.id').href;
---

<Layout
  title={`${umkm.nama} — UMKM Desa Sindangsari`}
  description={`${umkm.nama} · ${umkm.kategori} · ${umkm.lokasi ?? 'Desa Sindangsari'}`}
  ogImage={coverSrc ?? undefined}
>

  <!-- Header -->
  <div class="py-10 md:py-12" style="background:linear-gradient(135deg,#166534,#14532D);">
    <div class="mx-auto max-w-6xl px-4 md:px-6 text-white">
      <nav aria-label="Breadcrumb" class="text-sm mb-3 opacity-75">
        <a href="/" class="hover:underline">Beranda</a> /
        <a href="/umkm" class="hover:underline">Direktori UMKM</a> /
        <span>{umkm.nama}</span>
      </nav>
      <h1 class="font-heading font-bold text-3xl md:text-4xl">{umkm.nama}</h1>
      <p class="text-white/70 mt-1">{umkm.kategori}</p>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 md:px-6 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-10">

      <!-- Left: gallery + description + location -->
      <div>
        <!-- Cover image -->
        {coverSrc ? (
          <div class="aspect-[16/10] rounded-xl overflow-hidden mb-6 border border-border" style="box-shadow:var(--shadow-md);">
            <img src={coverSrc} alt={coverAlt}
              class="w-full h-full object-cover" loading="lazy" />
          </div>
        ) : (
          <div class="aspect-[16/10] rounded-xl overflow-hidden mb-6 flex items-center justify-center" style="background:var(--color-sand);">
            <span class="font-heading font-bold text-6xl" style="color:var(--color-primary); opacity:.2;">{umkm.nama[0]}</span>
          </div>
        )}

        <!-- Gallery -->
        {galleryList.length > 0 && (
          <div class="grid grid-cols-3 gap-2 mb-6">
            {galleryList.map(m => (
              <div class="aspect-square rounded-lg overflow-hidden border border-border">
                <img src={mediaUrl(m.r2_key_thumb)} alt={m.alt}
                  class="w-full h-full object-cover" loading="lazy" />
              </div>
            ))}
          </div>
        )}

        <!-- Description -->
        <div class="prose max-w-none mb-6" set:html={umkm.deskripsi_html} />

        <!-- Location -->
        {umkm.lokasi && (
          <div class="flex items-start gap-3 p-4 rounded-xl border border-border" style="background:var(--color-bg);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" class="mt-0.5 shrink-0" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <p class="font-heading font-medium text-sm">Lokasi</p>
              <p class="text-text-muted text-sm">{umkm.lokasi}</p>
              {umkm.google_maps_url && (
                <a href={umkm.google_maps_url} target="_blank" rel="noopener noreferrer"
                  class="text-accent text-sm hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent rounded">
                  Buka di Google Maps →
                </a>
              )}
            </div>
          </div>
        )}
      </div>

      <!-- Right: sticky contact card -->
      <aside class="lg:sticky lg:top-24 self-start">
        <div class="bg-white rounded-xl border border-border p-6 space-y-3" style="box-shadow:var(--shadow-md);">
          <h2 class="font-heading font-bold text-lg mb-4" style="color:var(--color-primary);">Hubungi UMKM</h2>

          <!-- 1. Primary contact -->
          {umkm.wa_number ? (
            <a href={`https://wa.me/${umkm.wa_number.replace(/\D/g,'')}`} target="_blank" rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-lg font-heading font-semibold text-white transition-opacity hover:opacity-90 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
              style="background:var(--color-cta); min-height:44px;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
              Hubungi via WhatsApp
            </a>
          ) : umkm.telepon ? (
            <a href={`tel:${umkm.telepon}`}
              class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-lg font-heading font-semibold border transition-colors hover:bg-primary hover:text-white focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
              style="border-color:var(--color-primary); color:var(--color-primary); min-height:44px;">
              Telepon
            </a>
          ) : null}

          <!-- 2. Toko online -->
          {umkm.toko_online_url && (
            <a href={umkm.toko_online_url} target="_blank" rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-lg font-heading font-semibold border transition-colors hover:bg-primary hover:text-white focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
              style="border-color:var(--color-primary); color:var(--color-primary); min-height:44px;">
              Beli di Toko Online
            </a>
          )}

          <!-- 3. Secondary: Maps + QRIS -->
          {(umkm.google_maps_url || umkm.qris_r2_key) && (
            <div class="grid grid-cols-2 gap-2">
              {umkm.google_maps_url && (
                <a href={umkm.google_maps_url} target="_blank" rel="noopener noreferrer"
                  class="flex items-center justify-center px-3 py-2 rounded-lg font-heading font-medium text-sm border hover:bg-sand focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
                  style="border-color:var(--color-border); color:var(--color-text); min-height:44px;">
                  Google Maps
                </a>
              )}
              {umkm.qris_r2_key && (
                <a href={`/api/media/${encodeURIComponent(umkm.qris_r2_key)}`} target="_blank"
                  class="flex items-center justify-center px-3 py-2 rounded-lg font-heading font-medium text-sm border hover:bg-sand focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
                  style="border-color:var(--color-border); color:var(--color-text); min-height:44px;">
                  QRIS
                </a>
              )}
            </div>
          )}

          <!-- 4. Share -->
          <div class="pt-3 border-t border-border">
            <p class="text-text-muted text-xs font-heading mb-2">Bagikan</p>
            <div class="flex gap-2">
              <a href={`https://wa.me/?text=${encodeURIComponent(umkm.nama + ' — ' + canonicalUrl)}`}
                target="_blank" rel="noopener noreferrer" aria-label="Bagikan via WhatsApp"
                class="w-10 h-10 rounded-lg border border-border flex items-center justify-center hover:bg-sand focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
              </a>
              <button id="copy-link" type="button" aria-label="Salin tautan"
                class="w-10 h-10 rounded-lg border border-border flex items-center justify-center hover:bg-sand cursor-pointer focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              </button>
              <span id="copy-confirm" class="text-xs text-cta hidden self-center ml-1">Tautan disalin!</span>
            </div>
          </div>
        </div>

        <!-- Disclaimer -->
        <p class="text-xs text-text-muted mt-3 text-center italic">
          Transaksi dilakukan langsung dengan UMKM. Pemerintah Desa Sindangsari tidak memungut biaya apapun.
        </p>
      </aside>

    </div>
  </div>

</Layout>

<script define:vars={{ canonicalUrl }}>
  document.getElementById('copy-link')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(canonicalUrl);
    const msg = document.getElementById('copy-confirm');
    if (msg) { msg.classList.remove('hidden'); setTimeout(() => msg.classList.add('hidden'), 2000); }
  });
</script>

<style>
  .prose h2 { font-size:1.125rem; font-weight:700; color:var(--color-primary); margin:1rem 0 .5rem; }
  .prose p { margin:.5rem 0; line-height:1.7; }
</style>
