---
import Layout from '../../components/Layout.astro';
import { getLayananBySlug, getPublishedLayanan, waRequestLink, kategoriIcon, isGratis } from '../../lib/db/layanan';
import { coverUrl } from '../../lib/db/media';
import { getEnv } from '@lib/env';

const env = getEnv();
const { slug } = Astro.params;
const layanan = env && slug ? await getLayananBySlug(slug, env.DB) : null;

if (!layanan) return Astro.redirect('/404');

const waLink = waRequestLink(layanan);
const posterUrl = coverUrl(layanan);

// "Layanan lainnya" — same category first, then anything else, max 3.
const semua = await getPublishedLayanan(env!.DB);
const lainnya = semua
  .filter((l) => l.slug !== layanan.slug)
  .sort((a, b) => Number(b.kategori === layanan.kategori) - Number(a.kategori === layanan.kategori))
  .slice(0, 3);

// HowTo structured data — lets the procedure surface directly in search results.
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `Cara Mengurus ${layanan.nama} di Desa Sindangsari`,
  description: layanan.ringkasan,
  totalTime: layanan.estimasi_waktu,
  estimatedCost: layanan.biaya,
  supply: layanan.persyaratan.map((p) => ({ '@type': 'HowToSupply', name: p })),
  step: layanan.alur.map((s, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.judul,
    text: s.keterangan || s.judul,
  })),
};

// Biaya & waktu naik ke strip ringkas di atas; sidebar menyisakan keterangan formal.
const ketentuan = [
  { icon: 'user-check', label: 'Penanggung Jawab', value: layanan.penanggung_jawab },
  { icon: 'scale', label: 'Dasar Hukum', value: layanan.dasar_hukum },
].filter((k) => k.value);

const ringkas = [
  { icon: 'wallet', label: 'Biaya', value: layanan.biaya, hi: isGratis(layanan.biaya) },
  { icon: 'clock', label: 'Lama proses', value: layanan.estimasi_waktu, hi: false },
  { icon: 'list-checks', label: 'Berkas dibawa', value: `${layanan.persyaratan.length} berkas`, hi: false },
];
---

<Layout
  title={`${layanan.nama} — Layanan Desa Sindangsari`}
  description={layanan.ringkasan || `Persyaratan dan alur pelayanan ${layanan.nama} di Desa Sindangsari.`}
>

<script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

<main id="main">

  <!-- ── Header ── -->
  <div class="bg-sand/40 border-b border-line">
    <div class="mx-auto max-w-[1152px] px-4 sm:px-6 pt-6 pb-8">
      <nav aria-label="Breadcrumb" class="text-sm text-muted flex flex-wrap items-center gap-1.5">
        <a href="/" class="hover:text-accent">Beranda</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <a href="/layanan" class="hover:text-accent">Layanan</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-ink font-medium">{layanan.nama}</span>
      </nav>

      <div class="flex items-start gap-4 mt-4">
        <span class="w-14 h-14 shrink-0 rounded-2xl bg-white border border-line grid place-items-center" aria-hidden="true">
          <i data-lucide={kategoriIcon(layanan.kategori)} class="w-7 h-7 text-primary"></i>
        </span>
        <div class="min-w-0">
          <span class="text-sm font-heading font-semibold text-muted">{layanan.kategori}</span>
          <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-primary leading-tight">{layanan.nama}</h1>
        </div>
      </div>

      {layanan.ringkasan && (
        <p class="text-muted text-lg mt-4 max-w-3xl">{layanan.ringkasan}</p>
      )}

      <!-- Jawaban langsung atas tiga pertanyaan pertama warga, sebelum harus membaca apa pun. -->
      <dl class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-3xl">
        {ringkas.map(({ icon, label, value, hi }) => (
          <div class={`rounded-xl border p-4 flex items-center gap-3 ${hi ? 'border-accent/30 bg-accent/5' : 'border-line bg-white'}`}>
            <i data-lucide={icon} class={`w-5 h-5 shrink-0 ${hi ? 'text-accent' : 'text-primary'}`} aria-hidden="true"></i>
            <div class="min-w-0">
              <dt class="text-xs text-muted">{label}</dt>
              <dd class={`font-heading font-bold mt-0.5 ${hi ? 'text-accent' : 'text-ink'}`}>{value}</dd>
            </div>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <div class="mx-auto max-w-[1152px] px-4 sm:px-6 py-8">
    <div class="grid lg:grid-cols-3 gap-8">

      <!-- ── Kolom utama: persyaratan + alur ── -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Persyaratan -->
        <section aria-labelledby="h-syarat">
          <h2 id="h-syarat" class="font-heading font-bold text-xl text-primary flex items-center gap-2">
            <i data-lucide="list-checks" class="w-5 h-5"></i>
            Berkas yang Dibawa
          </h2>
          <p class="text-sm text-muted mt-1">Siapkan dari rumah agar selesai dalam sekali datang.</p>

          <ul class="mt-4 space-y-2.5">
            {layanan.persyaratan.map((syarat) => (
              <li class="flex items-start gap-3 bg-white border border-line rounded-lg p-3.5">
                <i data-lucide="check" class="w-5 h-5 text-accent shrink-0 mt-0.5"></i>
                <span class="text-ink">{syarat}</span>
              </li>
            ))}
          </ul>

          {layanan.form_url && (
            <a href={layanan.form_url} target="_blank" rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-2 border-2 border-primary text-primary hover:bg-primary hover:text-white font-heading font-semibold px-4 py-2.5 rounded-lg transition-colors min-h-[44px]">
              <i data-lucide="download" class="w-4 h-4"></i>
              Unduh Formulir
            </a>
          )}
        </section>

        <!-- Alur pelayanan -->
        <section aria-labelledby="h-alur">
          <h2 id="h-alur" class="font-heading font-bold text-xl text-primary flex items-center gap-2">
            <i data-lucide="route" class="w-5 h-5"></i>
            Alur Pelayanan
          </h2>
          <p class="text-sm text-muted mt-1">Ikuti langkah berikut secara berurutan.</p>

          <ol class="mt-5 relative">
            {layanan.alur.map((langkah, i) => (
              <li class="relative flex gap-4 pb-6 last:pb-0">
                <!-- Connector line -->
                {i < layanan.alur.length - 1 && (
                  <span class="absolute left-[19px] top-11 bottom-0 w-0.5 bg-line" aria-hidden="true"></span>
                )}

                <span
                  class="relative z-10 w-10 h-10 shrink-0 rounded-full grid place-items-center font-heading font-bold text-white bg-primary"
                  aria-hidden="true"
                >
                  {i + 1}
                </span>

                <div class="flex-1 bg-white border border-line rounded-xl p-4 shadow-[0_2px_6px_rgba(16,35,26,.05)]">
                  <h3 class="font-heading font-semibold text-ink">
                    <span class="sr-only">Langkah {i + 1}: </span>{langkah.judul}
                  </h3>
                  {langkah.keterangan && (
                    <p class="text-sm text-muted mt-1">{langkah.keterangan}</p>
                  )}
                </div>
              </li>
            ))}
          </ol>
        </section>

        <!-- Poster / pamflet — pendamping visual, bukan sumber utama, jadi ditaruh setelah alur. -->
        {posterUrl && (
          <section aria-labelledby="h-poster">
            <h2 id="h-poster" class="font-heading font-bold text-xl text-primary flex items-center gap-2">
              <i data-lucide="image" class="w-5 h-5"></i>
              Poster / Pamflet
            </h2>
            <a href={posterUrl} target="_blank" rel="noopener noreferrer"
              class="mt-4 block rounded-xl overflow-hidden border border-line bg-white shadow-[0_2px_6px_rgba(16,35,26,.05)] hover:shadow-[0_12px_24px_rgba(16,35,26,.12)] transition-shadow">
              <img src={posterUrl} alt={layanan.cover_alt || `Poster layanan ${layanan.nama}`}
                class="w-full h-auto" loading="lazy" />
            </a>
            <p class="text-xs text-muted mt-2">Ketuk gambar untuk memperbesar.</p>
          </section>
        )}

      </div>

      <!-- ── Sidebar: ketentuan + pengajuan ── -->
      <aside class="lg:col-span-1">
        <div class="lg:sticky lg:top-24 space-y-5">

          <!-- Pengajuan -->
          <div class="bg-white border border-line rounded-xl p-5 shadow-[0_4px_10px_rgba(16,35,26,.08)]">
            <h2 class="font-heading font-bold text-ink">Ajukan Layanan</h2>
            <p class="text-sm text-muted mt-1">
              Tanyakan kesiapan berkas lewat WhatsApp, atau datang langsung ke Kantor Desa.
            </p>

            {waLink ? (
              <a href={waLink} target="_blank" rel="noopener noreferrer"
                class="mt-4 inline-flex items-center justify-center gap-2 w-full bg-cta hover:bg-ctaDark text-white font-heading font-semibold py-2.5 rounded-lg transition-colors min-h-[44px]">
                <i data-lucide="message-circle" class="w-4 h-4"></i>
                Ajukan via WhatsApp
              </a>
            ) : (
              <a href="/kontak"
                class="mt-4 inline-flex items-center justify-center gap-2 w-full bg-cta hover:bg-ctaDark text-white font-heading font-semibold py-2.5 rounded-lg transition-colors min-h-[44px]">
                <i data-lucide="phone" class="w-4 h-4"></i>
                Hubungi Kantor Desa
              </a>
            )}

            <dl class="mt-4 pt-4 border-t border-line flex items-start gap-2.5">
              <i data-lucide="clock" class="w-4 h-4 text-primary shrink-0 mt-0.5" aria-hidden="true"></i>
              <div>
                <dt class="text-xs font-heading font-semibold text-ink">Jam pelayanan</dt>
                <dd class="text-xs text-muted mt-0.5">Senin–Jumat, 08.00–15.00 WIB</dd>
                <dd class="text-xs text-muted">Istirahat 12.00–13.00 WIB</dd>
              </div>
            </dl>
          </div>

          <!-- Ketentuan formal: paling jarang dibutuhkan warga, jadi paling bawah. -->
          {ketentuan.length > 0 && (
            <div class="bg-white border border-line rounded-xl p-5 shadow-[0_4px_10px_rgba(16,35,26,.08)]">
              <h2 class="font-heading font-bold text-ink">Ketentuan Pelayanan</h2>
              <dl class="mt-4 space-y-4">
                {ketentuan.map(({ icon, label, value }) => (
                  <div class="flex items-start gap-3">
                    <i data-lucide={icon} class="w-4 h-4 text-primary shrink-0 mt-1" aria-hidden="true"></i>
                    <div>
                      <dt class="text-xs text-muted">{label}</dt>
                      <dd class="text-sm font-medium text-ink mt-0.5">{value}</dd>
                    </div>
                  </div>
                ))}
              </dl>
            </div>
          )}

          <p class="text-xs text-muted flex items-start gap-2 px-1">
            <i data-lucide="shield-check" class="w-3.5 h-3.5 text-accent shrink-0 mt-0.5" aria-hidden="true"></i>
            <span>Laporkan bila ada pungutan di luar ketentuan di atas.</span>
          </p>

        </div>
      </aside>

    </div>

    <!-- ── Layanan lainnya ── -->
    {lainnya.length > 0 && (
      <section aria-labelledby="h-lainnya" class="mt-12 pt-8 border-t border-line">
        <h2 id="h-lainnya" class="font-heading font-bold text-xl text-primary">Layanan Lainnya</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-5">
          {lainnya.map((l) => (
            <a href={`/layanan/${l.slug}`}
              class="group bg-white border border-line rounded-xl p-5 shadow-[0_4px_10px_rgba(16,35,26,.08)] hover:shadow-[0_12px_24px_rgba(16,35,26,.12)] hover:border-accent transition-all flex items-start gap-3">
              <span class="w-10 h-10 shrink-0 rounded-xl bg-sand grid place-items-center" aria-hidden="true">
                <i data-lucide={kategoriIcon(l.kategori)} class="w-5 h-5 text-primary"></i>
              </span>
              <div class="min-w-0">
                <span class="text-xs font-heading font-semibold text-muted">{l.kategori}</span>
                <h3 class="font-heading font-semibold text-ink group-hover:text-primary leading-snug">{l.nama}</h3>
                <p class="text-xs text-muted mt-1.5">{l.persyaratan.length} berkas · {l.estimasi_waktu}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="mt-10">
      <a href="/layanan" class="inline-flex items-center gap-2 text-sm font-heading font-semibold text-accent hover:underline">
        <i data-lucide="arrow-left" class="w-4 h-4"></i>
        Kembali ke semua layanan
      </a>
    </div>

  </div>
</main>

</Layout>
