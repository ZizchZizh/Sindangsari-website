---
interface Props {
  type: 'wisata' | 'umkm' | 'potensi';
  class?: string;
}

const { type, class: className } = Astro.props;

const labels: Record<string, string> = {
  wisata: 'Wisata',
  umkm: 'UMKM',
  potensi: 'Potensi',
};

const colorClasses: Record<string, string> = {
  wisata: 'bg-[#D1FAE5] text-[#047857]',
  umkm: 'bg-[#E3F2E8] text-[#126B33]',
  potensi: 'bg-[#E3F2E8] text-[#166534]',
};
---

<span
  class:list={[
    'inline-block text-[13px] font-semibold px-[10px] py-[4px] rounded-full',
    colorClasses[type],
    className,
  ]}
>
  {labels[type]}
</span>
