---
import Layout from '../../components/Layout.astro';
import { getPublishedBerita, formatTanggal, excerpt } from '../../lib/db/berita';
import { getEnv } from '@lib/env';

const env = getEnv();
const beritaList = env ? await getPublishedBerita(env.DB) : [];

const demoBerita = [
  { slug: 'gotong-royong-jalan-desa', judul: 'Gotong Royong Warga Sindangsari Bersihkan Lingkungan Desa', published_at: '2026-07-12', content_html: '<p>Warga bersama Karang Taruna bergotong royong membersihkan lingkungan kampung dan saluran air menjelang musim hujan, menjaga desa tetap asri dan sehat.</p>', featured: true, img: '/images/gotong_royong.png' },
  { slug: 'pelatihan-digital-umkm', judul: 'Pelatihan Digital untuk UMKM Desa', published_at: '2026-07-08', content_html: '<p>Sepuluh pelaku UMKM mengikuti pelatihan foto produk dan WhatsApp Business yang difasilitasi oleh Tim KKNT IPB.</p>', featured: false, img: '/images/pelatihan_umkm.png' },
  { slug: 'peluncuran-situs-resmi', judul: 'Peluncuran Situs Resmi Desa Sindangsari', published_at: '2026-07-01', content_html: '<p>Desa Sindangsari kini punya kehadiran digital resmi yang dapat diakses siapa saja untuk mengeksplorasi potensi dan layanan desa.</p>', featured: false, img: '/images/pelatihan_umkm.png' },
  { slug: 'musyawarah-pengembangan-wisata', judul: 'Musyawarah Desa Bahas Pengembangan Ekowisata', published_at: '2026-06-24', content_html: '<p>Perangkat desa dan warga membahas rencana pengembangan potensi ekowisata alam Kasomalang berbasis pemberdayaan masyarakat lokal.</p>', featured: false, img: '/images/gotong_royong.png' },
  { slug: 'panen-raya-padi', judul: 'Panen Raya Padi Sawah Sindangsari', published_at: '2026-06-18', content_html: '<p>Hasil panen padi tahun ini meningkat dibanding musim sebelumnya berkat pengelolaan irigasi mitra cai dan metode budidaya baru yang diterapkan kelompok tani.</p>', featured: false, img: '/images/sawah_sindangsari.png' },
  { slug: 'kerja-bakti-jalan-desa', judul: 'Kerja Bakti Perbaikan Jalan Usaha Tani', published_at: '2026-06-02', content_html: '<p>Warga bergotong royong memperbaiki ruas jalan usaha tani agar hasil panen lebih mudah diangkut dari sawah dan kebun menuju pasar.</p>', featured: false, img: '/images/gotong_royong.png' },
];

const getBeritaImg = (i: number) => {
  const imgs = ['/images/gotong_royong.png', '/images/pelatihan_umkm.png', '/images/pelatihan_umkm.png', '/images/gotong_royong.png', '/images/sawah_sindangsari.png', '/images/gotong_royong.png'];
  return imgs[i % imgs.length];
};

const finalBerita = beritaList.length > 0
  ? beritaList.map((b, i) => ({ slug: b.slug, judul: b.judul, published_at: b.published_at ?? '', content_html: b.content_html, featured: i === 0, img: getBeritaImg(i) }))
  : demoBerita;

const featuredBerita = finalBerita[0];
const restBerita = finalBerita.slice(1);
---

<Layout
  title="Berita — Desa Sindangsari"
  description="Berita dan pengumuman resmi terbaru dari Pemerintah Desa Sindangsari, Kecamatan Kasomalang, Kabupaten Subang."
>

<main id="main" class="mx-auto max-w-[1152px] px-4 sm:px-6 py-10">
  <h1 class="text-3xl sm:text-4xl font-heading font-extrabold text-primary">Berita & Pengumuman</h1>
  <p class="text-muted mt-2">Kabar terbaru dari Desa Sindangsari.</p>

  {/* Featured article */}
  {featuredBerita && (
    <a href={`/berita/${featuredBerita.slug}`}
       class="group grid md:grid-cols-2 gap-0 items-stretch bg-white border border-line rounded-2xl overflow-hidden shadow-[0_4px_10px_rgba(16,35,26,.08)] hover:shadow-[0_12px_24px_rgba(16,35,26,.12)] hover:border-accent transition-all mt-6">
      <div class="aspect-[16/10] md:aspect-auto overflow-hidden">
        {featuredBerita.img ? (
          <img
            src={featuredBerita.img}
            alt={featuredBerita.judul}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="eager"
          />
        ) : (
          <div class="w-full h-full min-h-[200px]" style="background: linear-gradient(135deg, #166534 0%, #059669 60%, #34D399 100%);"></div>
        )}
      </div>
      <div class="p-6 sm:p-8 flex flex-col justify-center">
        <span class="text-[13px] font-heading font-semibold px-2.5 py-1 rounded-full bg-[#D1FAE5] text-[#047857] w-max">Terbaru</span>
        <time class="text-sm text-muted mt-3">
          {featuredBerita.published_at ? formatTanggal(featuredBerita.published_at) : ''}
        </time>
        <h2 class="font-heading font-extrabold text-2xl text-ink mt-1 group-hover:text-primary transition-colors leading-snug">
          {featuredBerita.judul}
        </h2>
        <p class="text-muted mt-2 line-clamp-3">{excerpt(featuredBerita.content_html, 160)}</p>
        <span class="inline-flex items-center gap-1.5 mt-4 text-accent font-heading font-semibold">
          Baca selengkapnya <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </span>
      </div>
    </a>
  )}

  {/* Rest grid */}
  {restBerita.length > 0 && (
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-6">
      {restBerita.map(b => (
        <a href={`/berita/${b.slug}`}
           class="group block bg-white border border-line rounded-2xl overflow-hidden shadow-[0_4px_10px_rgba(16,35,26,.08)] hover:shadow-[0_12px_24px_rgba(16,35,26,.12)] hover:border-accent transition-all">
          <div class="aspect-[16/9] overflow-hidden">
            {b.img ? (
              <img src={b.img} alt={b.judul} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            ) : (
              <div class="w-full h-full" style="background: linear-gradient(135deg, #166534 0%, #059669 60%, #34D399 100%);"></div>
            )}
          </div>
          <div class="p-5">
            <time class="text-xs font-heading font-semibold text-muted">
              {b.published_at ? formatTanggal(b.published_at) : ''}
            </time>
            <h3 class="font-heading font-semibold text-ink mt-1 group-hover:text-primary transition-colors leading-snug">{b.judul}</h3>
            <p class="text-sm text-muted mt-1 line-clamp-2">{excerpt(b.content_html, 100)}</p>
          </div>
        </a>
      ))}
    </div>
  )}

  {finalBerita.length === 0 && (
    <div class="text-center py-20">
      <p class="font-heading font-medium text-lg text-muted">Belum ada berita. Kunjungi lagi nanti.</p>
    </div>
  )}
</main>

</Layout>

<script is:inline>
  setTimeout(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); }, 300);
</script>
