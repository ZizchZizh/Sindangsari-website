---
import Layout from '../components/Layout.astro';
import { getAllTitikPeta } from '../lib/db/titik-peta';
import { getEnv } from '@lib/env';

const env = getEnv();
const titikList = env ? await getAllTitikPeta(env.DB) : [];
const titikJson = JSON.stringify(titikList);

const counts = { wisata: 0, umkm: 0, potensi: 0 };
for (const t of titikList) {
  if (t.jenis in counts) counts[t.jenis as keyof typeof counts]++;
}

const demoPoints = [
  { jenis: 'wisata', label: 'Curug Masigit', lat: -6.7150, lng: 107.7350, linked_slug: 'curug-masigit', desc: 'Air terjun eksotis di Desa Pasanggrahan, selatan Sindangsari.' },
  { jenis: 'wisata', label: 'Ekowisata Kasomalang', lat: -6.7100, lng: 107.7300, linked_slug: 'ekowisata-alam-kasomalang', desc: 'Ekowisata alam pegunungan.' },
  { jenis: 'wisata', label: 'Panorama Sawah Sindangsari', lat: -6.7000, lng: 107.7450, linked_slug: 'panorama-sawah-sindangsari', desc: 'Pemandangan sawah dataran tinggi.' },
  { jenis: 'umkm', label: 'Kerupuk, Opak & Ranginang', lat: -6.7010, lng: 107.7420, linked_slug: 'kerupuk-opak-ranginang', desc: 'Makanan tradisional khas Sunda — Kp. Limaratus.' },
  { jenis: 'umkm', label: 'Kopi Aren Kasomalang', lat: -6.7030, lng: 107.7400, linked_slug: 'kopi-aren-kasomalang', desc: 'Kuliner — kopi aren dataran tinggi.' },
  { jenis: 'potensi', label: 'Sawah Sindangsari', lat: -6.7050, lng: 107.7380, linked_slug: 'potensi', desc: 'Potensi pertanian padi — 161 ha sawah.' },
  { jenis: 'potensi', label: 'Kebun Buah', lat: -6.6990, lng: 107.7440, linked_slug: 'potensi', desc: 'Alpukat, durian, jeruk bali, nangka, dan nanas.' },
];

const finalPoints = titikList.length > 0 ? titikList : demoPoints;
const finalJson = JSON.stringify(finalPoints);
const finalCounts = titikList.length > 0
  ? counts
  : { wisata: demoPoints.filter(p => p.jenis === 'wisata').length, umkm: demoPoints.filter(p => p.jenis === 'umkm').length, potensi: demoPoints.filter(p => p.jenis === 'potensi').length };
---

<Layout
  title="Peta Desa — Desa Sindangsari"
  description="Peta interaktif Desa Sindangsari: titik wisata, UMKM, dan potensi desa. Klik penanda untuk detail."
>

<main id="main" class="mx-auto max-w-[1152px] px-4 sm:px-6 py-6">
  <h1 class="text-2xl sm:text-3xl font-heading font-extrabold text-primary">Peta Desa Sindangsari</h1>
  <p class="text-muted mt-1">Jelajahi titik wisata, UMKM, dan potensi desa. Klik penanda untuk detail.</p>

  <div class="grid lg:grid-cols-[280px_1fr] gap-5 mt-5">
    <!-- Filter panel -->
    <aside class="bg-white border border-line rounded-2xl p-5 h-max shadow-[0_4px_10px_rgba(16,35,26,.08)]">
      <h2 class="font-heading font-semibold text-ink">Tampilkan</h2>
      <div class="space-y-2 mt-3">
        {[
          { type: 'wisata', label: 'Wisata', icon: 'palmtree', color: '#0D9488', count: finalCounts.wisata },
          { type: 'umkm', label: 'UMKM', icon: 'store', color: '#15803D', count: finalCounts.umkm },
          { type: 'potensi', label: 'Potensi', icon: 'sprout', color: '#B45309', count: finalCounts.potensi },
        ].map(item => (
          <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-sand cursor-pointer">
            <input type="checkbox" class="filter-check w-4 h-4 rounded text-accent" data-type={item.type} checked />
            <span class="w-7 h-7 rounded-full grid place-items-center shrink-0" style={`background:${item.color}; transform:rotate(-45deg);`}>
              <i data-lucide={item.icon} class="w-3.5 h-3.5 text-white" style="transform:rotate(45deg);"></i>
            </span>
            <span class="font-medium text-sm">{item.label}</span>
            <span class="ml-auto text-sm text-muted">{item.count}</span>
          </label>
        ))}
      </div>
      <hr class="my-4 border-line" />
      <button id="resetView" class="inline-flex items-center gap-2 w-full justify-center border-2 border-primary text-primary font-heading font-semibold py-2.5 rounded-lg hover:bg-primary hover:text-white transition-colors min-h-[44px] text-sm">
        <i data-lucide="locate-fixed" class="w-5 h-5"></i> Pusatkan ke Desa
      </button>
      <p class="text-xs text-muted mt-3 flex items-center gap-1.5">
        <i data-lucide="info" class="w-4 h-4"></i> Peta gratis berbasis OpenStreetMap.
      </p>
      <div class="mt-4 bg-sand/60 border border-line rounded-lg p-3 flex gap-2">
        <i data-lucide="shield-check" class="w-4 h-4 text-primary shrink-0 mt-0.5"></i>
        <p class="text-xs text-muted">
          <span class="font-heading font-semibold text-ink">Pengelola desa</span> dapat menambah, menyunting, atau menghapus titik peta melalui <span class="font-medium text-primary">Panel Admin › Kelola Peta</span>.
        </p>
      </div>
    </aside>

    <!-- Map -->
    <div id="peta-map" class="rounded-2xl overflow-hidden border border-line shadow-[0_4px_12px_rgba(16,35,26,.10)]" style="height: min(70vh, 640px); z-index: 0;"></div>
  </div>
</main>

</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

<script define:vars={{ finalJson }}>
  const CENTER = [-6.7022, 107.7414], ZOOM = 13;
  const map = L.map('peta-map', { scrollWheelZoom: false }).setView(CENTER, ZOOM);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19, attribution: '© OpenStreetMap' }).addTo(map);
  map.on('focus', () => map.scrollWheelZoom.enable());
  map.on('blur', () => map.scrollWheelZoom.disable());

  const COLORS = { wisata: '#0D9488', umkm: '#15803D', potensi: '#B45309' };
  const LINK = { wisata: '/wisata/', umkm: '/umkm/', potensi: '/potensi' };

  const points = JSON.parse(finalJson);
  const layers = { wisata: L.layerGroup(), umkm: L.layerGroup(), potensi: L.layerGroup() };

  points.forEach(p => {
    const color = COLORS[p.jenis] ?? '#666';
    const icon = L.divIcon({
      className: '',
      html: `<div style="width:24px;height:24px;background:${color};border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,.3);"></div>`,
      iconSize: [24, 24],
      iconAnchor: [12, 24],
      popupAnchor: [0, -26]
    });
    const href = p.jenis === 'potensi' ? '/potensi' : (LINK[p.jenis] ?? '/') + p.linked_slug;
    L.marker([p.lat, p.lng], { icon, title: p.label })
      .bindPopup(`<h3 style="font-family:Lexend,sans-serif;font-weight:700;color:#166534;margin:0 0 4px">${p.label}</h3><p style="margin:0 0 6px;color:#475569;font-size:.85rem">${p.desc ?? ''}</p><a href="${href}" style="color:#059669;font-weight:600;font-size:.85rem">Lihat detail →</a>`)
      .addTo(layers[p.jenis] ?? layers.wisata);
  });

  Object.values(layers).forEach(l => l.addTo(map));

  document.querySelectorAll('.filter-check').forEach(cb => {
    cb.addEventListener('change', () => {
      const t = cb.dataset.type;
      cb.checked ? layers[t].addTo(map) : map.removeLayer(layers[t]);
    });
  });

  document.getElementById('resetView').addEventListener('click', () => map.setView(CENTER, ZOOM));

  setTimeout(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); }, 150);
</script>
