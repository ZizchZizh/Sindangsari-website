---
import AdminLayout from '../../../components/AdminLayout.astro';
import { getPerangkatById, JABATAN_UMUM } from '../../../lib/db/perangkat-desa';
import { getEnv } from '@lib/env';

const env = getEnv();
const id = Number(Astro.params.id);
const perangkat = env && id ? await getPerangkatById(id, env.DB) : null;

if (!perangkat) return Astro.redirect('/admin/perangkat');

const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');
---

<AdminLayout title={`Sunting ${perangkat.nama}`} breadcrumb="Perangkat Desa / Sunting">

  {saved && (
    <div role="status" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#D1FAE5; color:#065F46; border:1px solid #6EE7B7;">
      Perubahan berhasil disimpan.
    </div>
  )}
  {error && (
    <div role="alert" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#FEE2E2; color:#991B1B; border:1px solid #FECACA;">
      Nama dan jabatan wajib diisi.
    </div>
  )}

  <div class="max-w-2xl">
    <div class="flex items-start justify-between gap-4 mb-6">
      <h2 class="font-heading font-bold text-xl" style="color:var(--color-primary);">Sunting Perangkat Desa</h2>
      <a href="/pemerintahan" target="_blank" rel="noopener"
        class="text-sm font-heading font-medium text-accent hover:underline shrink-0 mt-1">
        Lihat di situs ↗
      </a>
    </div>

    <form method="POST" action={`/api/admin/perangkat/${perangkat.id}`} class="space-y-5">

      <div>
        <label for="nama" class="block font-heading font-medium text-sm mb-1.5">
          Nama <span>*</span> <span class="font-normal text-text-muted">(wajib)</span>
        </label>
        <input type="text" id="nama" name="nama" required value={perangkat.nama}
          class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border); min-height:44px;" />
        {perangkat.nama.includes('Segera Diisi') && (
          <p class="text-xs mt-1" style="color:#B45309;">
            Nama ini masih placeholder dan tampil apa adanya di halaman publik. Ganti dengan nama asli.
          </p>
        )}
      </div>

      <div>
        <label for="jabatan" class="block font-heading font-medium text-sm mb-1.5">
          Jabatan <span>*</span> <span class="font-normal text-text-muted">(wajib)</span>
        </label>
        <input type="text" id="jabatan" name="jabatan" required value={perangkat.jabatan} list="daftar-jabatan"
          class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border); min-height:44px;" />
        <datalist id="daftar-jabatan">
          {JABATAN_UMUM.map((j) => <option value={j}></option>)}
        </datalist>
        <p class="text-xs text-text-muted mt-1">
          Jabatan yang mengandung <strong>"Kepala Desa"</strong> tampil di puncak bagan struktur,
          <strong>"Sekretaris"</strong> di tingkat kedua, sisanya di grid bawah.
        </p>
      </div>

      <div>
        <label for="urutan" class="block font-heading font-medium text-sm mb-1.5">Urutan Tampil</label>
        <input type="number" id="urutan" name="urutan" min="0" step="1" value={String(perangkat.urutan)}
          class="rounded-lg border px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border); min-height:44px; width:120px;" />
        <p class="text-xs text-text-muted mt-1">Angka kecil tampil lebih dulu.</p>
      </div>

      <div class="sticky bottom-0 bg-white border-t border-border -mx-4 md:-mx-6 px-4 md:px-6 py-3 flex justify-end gap-3" style="box-shadow:0 -2px 8px rgba(0,0,0,.06);">
        <a href="/admin/perangkat"
          class="px-4 py-2 rounded-lg font-heading font-medium text-sm border hover:bg-sand"
          style="border-color:var(--color-border); min-height:44px; display:flex; align-items:center;">
          Batal
        </a>
        <button type="submit"
          class="px-5 py-2 rounded-lg font-heading font-semibold text-white text-sm cursor-pointer"
          style="background:var(--color-cta); min-height:44px;">
          Simpan Perubahan
        </button>
      </div>

    </form>
  </div>

</AdminLayout>
