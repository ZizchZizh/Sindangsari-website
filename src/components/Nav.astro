---
interface Props {
  transparent?: boolean;
  currentPath?: string;
}

const { transparent = false, currentPath = '/' } = Astro.props;

const navItems = [
  { href: '/', label: 'Beranda' },
  { href: '/profil', label: 'Profil' },
  { href: '/pemerintahan', label: 'Pemerintahan' },
  { href: '/potensi', label: 'Potensi' },
  { href: '/wisata', label: 'Wisata' },
  { href: '/umkm', label: 'UMKM' },
  { href: '/peta', label: 'Peta' },
  { href: '/berita', label: 'Berita' },
];
const isKontak = currentPath === '/kontak';

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header
  id="site-nav"
  data-transparent={transparent ? 'true' : 'false'}
  class="fixed top-0 inset-x-0 z-40 transition-[background-color,box-shadow] duration-200"
>
  <!-- Nav inner — height transitions 80px → 64px on scroll -->
  <div class="nav-inner mx-auto max-w-6xl px-4 md:px-6 flex items-center justify-between" style="height: 80px; transition: height 200ms ease;">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent focus-visible:rounded-sm">
      <span class="nav-logo-circle w-10 h-10 rounded-full grid place-items-center font-heading font-bold text-sm transition-colors duration-200"
        style="background: #fff; color: var(--color-primary);"
        aria-hidden="true"
      >DS</span>
      <span class="leading-tight">
        <span class="nav-brand-title block font-heading font-bold transition-colors duration-200" style="color: #fff;">Desa Sindangsari</span>
        <span class="nav-brand-sub block text-xs transition-colors duration-200" style="color: rgba(255,255,255,0.85);">Pemerintah Desa Sindangsari</span>
      </span>
    </a>

    <!-- Desktop nav links -->
    <nav aria-label="Navigasi utama" class="hidden lg:flex items-center gap-1 font-heading font-medium text-[15px]">
      {navItems.map(({ href, label }) => (
        <a
          href={href}
          aria-current={isActive(href) ? 'page' : undefined}
          class:list={[
            'nav-link px-3 py-2 rounded-md transition-colors duration-150 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent focus-visible:outline-offset-1',
            isActive(href) ? 'nav-link--active' : '',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="/kontak"
        aria-current={isKontak ? 'page' : undefined}
        class="ml-2 nav-kontak inline-flex items-center gap-1.5 px-3 py-2 rounded-md font-semibold transition-colors duration-150 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent focus-visible:outline-offset-1"
      >
        Kontak
      </a>
    </nav>

    <!-- Hamburger (mobile) -->
    <button
      id="nav-hamburger"
      class="nav-burger lg:hidden w-11 h-11 rounded-md flex items-center justify-center cursor-pointer transition-colors duration-150 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
      aria-label="Buka menu navigasi"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <!-- Hamburger SVG -->
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

  </div>
</header>

<!-- Backdrop overlay -->
<div
  id="nav-overlay"
  class="fixed inset-0 bg-black/40 z-40 hidden"
  aria-hidden="true"
></div>

<!-- Mobile drawer -->
<div
  id="nav-drawer"
  class="fixed inset-y-0 right-0 w-72 bg-white z-50 shadow-lg flex flex-col"
  style="transform: translateX(100%); transition: transform 200ms ease;"
  role="dialog"
  aria-label="Menu navigasi"
  aria-modal="true"
>
  <!-- Drawer header -->
  <div class="flex items-center justify-between px-4 py-4 border-b border-border">
    <span class="font-heading font-bold text-primary">Menu</span>
    <button
      id="nav-drawer-close"
      class="w-11 h-11 rounded-md flex items-center justify-center cursor-pointer hover:bg-sand transition-colors duration-150 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
      aria-label="Tutup menu"
    >
      <!-- Close SVG -->
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Drawer nav links -->
  <nav aria-label="Navigasi mobile" class="flex flex-col p-4 gap-1 font-heading font-medium">
    {navItems.map(({ href, label }) => (
      <a
        href={href}
        aria-current={isActive(href) ? 'page' : undefined}
        class:list={[
          'px-3 py-3 rounded-md transition-colors duration-150 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent text-base',
          isActive(href)
            ? 'bg-sand text-primary'
            : 'text-text hover:bg-sand',
        ]}
      >
        {label}
      </a>
    ))}
    <a
      href="/kontak"
      aria-current={isKontak ? 'page' : undefined}
      class:list={[
        'px-3 py-3 rounded-md transition-colors duration-150 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent text-base font-semibold',
        isKontak ? 'bg-primary text-white' : 'bg-primary text-white hover:bg-primary-dark',
      ]}
    >
      Kontak
    </a>
  </nav>
</div>

<style>
  /* ── Solid state (always applied on interior pages; toggled via JS on homepage) ── */
  #site-nav.nav-scrolled {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    box-shadow: 0 4px 12px rgba(16, 35, 26, 0.10);
  }
  #site-nav.nav-scrolled .nav-inner {
    height: 64px !important;
  }
  /* Logo in solid state */
  #site-nav.nav-scrolled .nav-logo-circle {
    background: var(--color-primary) !important;
    color: #fff !important;
  }
  #site-nav.nav-scrolled .nav-brand-title {
    color: var(--color-primary) !important;
  }
  #site-nav.nav-scrolled .nav-brand-sub {
    color: var(--color-text-muted) !important;
  }
  /* Desktop links in solid state */
  #site-nav.nav-scrolled .nav-link {
    color: var(--color-text);
  }
  #site-nav.nav-scrolled .nav-link:hover {
    background: var(--color-sand);
  }
  #site-nav.nav-scrolled .nav-link--active {
    background: var(--color-sand);
    color: var(--color-primary);
  }
  /* Hamburger in solid state */
  #site-nav.nav-scrolled .nav-burger {
    color: var(--color-primary);
    background: transparent;
  }

  /* ── Kontak CTA button ── */
  .nav-kontak {
    background: var(--color-primary);
    color: #fff;
  }
  .nav-kontak:hover {
    background: var(--color-primary-dark);
  }
  #site-nav.nav-scrolled .nav-kontak {
    background: var(--color-primary);
    color: #fff;
  }
  #site-nav.nav-scrolled .nav-kontak:hover {
    background: var(--color-primary-dark);
  }

  /* ── Transparent state (homepage at top) ── */
  #site-nav:not(.nav-scrolled) .nav-link {
    color: #fff;
  }
  #site-nav:not(.nav-scrolled) .nav-link:hover {
    background: rgba(255, 255, 255, 0.15);
  }
  #site-nav:not(.nav-scrolled) .nav-link--active {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }
  #site-nav:not(.nav-scrolled) .nav-burger {
    color: #fff;
    background: rgba(255, 255, 255, 0.15);
  }
  #site-nav:not(.nav-scrolled) .nav-kontak {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }
  #site-nav:not(.nav-scrolled) .nav-kontak:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  /* ── Mobile drawer open state ── */
  #nav-drawer.drawer-open {
    transform: translateX(0) !important;
  }
</style>

<script>
  const nav = document.getElementById('site-nav') as HTMLElement | null;
  const isTransparent = nav?.dataset.transparent === 'true';

  // ── Two-state scroll logic ──
  function updateNavState() {
    if (!nav) return;
    if (isTransparent) {
      nav.classList.toggle('nav-scrolled', window.scrollY > 12);
    } else {
      nav.classList.add('nav-scrolled');
    }
  }

  if (isTransparent) {
    window.addEventListener('scroll', updateNavState, { passive: true });
  }
  updateNavState();

  // ── Mobile drawer logic ──
  const hamburger = document.getElementById('nav-hamburger');
  const drawer = document.getElementById('nav-drawer');
  const overlay = document.getElementById('nav-overlay');
  const drawerClose = document.getElementById('nav-drawer-close');

  function openDrawer() {
    drawer?.classList.add('drawer-open');
    overlay?.classList.remove('hidden');
    hamburger?.setAttribute('aria-expanded', 'true');
    (drawerClose as HTMLElement | null)?.focus();
  }

  function closeDrawer() {
    drawer?.classList.remove('drawer-open');
    overlay?.classList.add('hidden');
    hamburger?.setAttribute('aria-expanded', 'false');
    (hamburger as HTMLElement | null)?.focus();
  }

  hamburger?.addEventListener('click', openDrawer);
  drawerClose?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && !overlay?.classList.contains('hidden')) {
      closeDrawer();
    }
  });
</script>
