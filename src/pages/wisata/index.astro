---
import Layout from '../../components/Layout.astro';
import { getPublishedWisata } from '../../lib/db/wisata';
import { excerpt } from '../../lib/db/berita';
import { getEnv } from '@lib/env';

const env = getEnv();
const wisataList = env ? await getPublishedWisata(env.DB) : [];

const demoWisata = [
  { slug: 'curug-masigit', nama: 'Curug Masigit', deskripsi_html: 'Air terjun eksotis di kawasan Kasomalang dengan air jernih berwarna hijau kebiruan, diapit tebing batu yang megah. Tersedia area berenang dan lokasi berkemah.', img: '/images/curug_masigit.png', tag: 'Air Terjun' },
  { slug: 'ekowisata-alam-kasomalang', nama: 'Ekowisata Alam Kasomalang', deskripsi_html: 'Kawasan ekowisata pegunungan dengan udara sejuk 15–25°C dan panorama perbukitan hijau. Cocok untuk hiking, agrowisata, dan menikmati keasrian alam Sunda.', img: '/images/ekowisata_kasomalang.png', tag: 'Alam' },
  { slug: 'panorama-sawah-sindangsari', nama: 'Panorama Sawah Sindangsari', deskripsi_html: 'Hamparan sawah 161 hektar berlatar perbukitan di ketinggian 500–600 mdpl. Spot terbaik menikmati matahari terbit dan udara pagi pegunungan.', img: '/images/sawah_sindangsari.png', tag: 'Panorama' },
  { slug: 'agrowisata-kebun-buah', nama: 'Agrowisata Kebun Buah', deskripsi_html: 'Kebun buah warga dengan alpukat, durian, jeruk bali, nangka, dan nanas khas Subang. Pengunjung dapat memetik buah langsung saat musim panen.', img: '/images/kebun_sayur.png', tag: 'Agrowisata' },
  { slug: 'jalur-hiking-perbukitan', nama: 'Jalur Hiking Perbukitan', deskripsi_html: 'Rute jelajah alam melintasi perbukitan, lembah, dan aliran mata air pegunungan yang jernih. Pemandu lokal siap menemani perjalanan Anda.', img: '/images/hero_sindangsari.png', tag: 'Alam' },
  { slug: 'wisata-budaya-kampung-limaratus', nama: 'Kampung Limaratus', deskripsi_html: 'Kampung terbesar sekaligus pusat aktivitas masyarakat desa. Dikenal dengan tradisi pembuatan kue dan makanan ringan khas Sunda secara turun-temurun.', img: '/images/gotong_royong.png', tag: 'Budaya' },
];

const getWisataImg = (slug: string) => {
  if (slug === 'curug-masigit') return '/images/curug_masigit.png';
  if (slug === 'ekowisata-alam-kasomalang') return '/images/ekowisata_kasomalang.png';
  return '/images/hero_sindangsari.png';
};

const displayList = wisataList.length > 0
  ? wisataList.map(w => ({ slug: w.slug, nama: w.nama, deskripsi_html: w.deskripsi_html, img: getWisataImg(w.slug), tag: 'Wisata' }))
  : demoWisata;
---

<Layout
  title="Wisata — Desa Sindangsari"
  description="Jelajahi destinasi wisata unggulan Desa Sindangsari: curug, ekowisata alam, agrowisata, dan budaya Sunda dataran tinggi Subang."
>

<!-- Hero -->
<section class="relative">
  <div class="h-48 sm:h-64 overflow-hidden">
    <img
      src="/images/hero_sindangsari.png"
      alt="Curug Masigit dan kawasan Ekowisata Kasomalang"
      class="w-full h-full object-cover"
    />
  </div>
  <div class="absolute inset-0" style="background: rgba(20,83,45,0.55);"></div>
  <div class="absolute inset-0 flex items-end">
    <div class="mx-auto max-w-[1152px] px-4 sm:px-6 w-full pb-6 text-white">
      <nav aria-label="Breadcrumb" class="text-sm text-white/80 flex items-center gap-1.5">
        <a href="/" class="hover:text-white">Beranda</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="font-medium">Wisata</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold mt-1">Destinasi Wisata Desa Sindangsari</h1>
      <p class="text-white/85 mt-1">Temukan keindahan alam dan budaya dataran tinggi Subang</p>
    </div>
  </div>
</section>

<main id="main" class="mx-auto max-w-[1152px] px-4 sm:px-6 py-10">
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {displayList.map(w => (
      <article class="group bg-white border border-line rounded-2xl overflow-hidden shadow-[0_4px_10px_rgba(16,35,26,.08)] hover:shadow-[0_12px_24px_rgba(16,35,26,.12)] hover:border-accent transition-all flex flex-col">
        <a href={`/wisata/${w.slug}`} class="block aspect-[16/10] overflow-hidden relative">
          {w.img ? (
            <img
              src={w.img}
              alt={w.nama}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-full" style="background: linear-gradient(135deg, #166534, #059669);"></div>
          )}
          <span class="absolute top-3 left-3 bg-white/90 backdrop-blur text-primary text-xs font-heading font-semibold px-2.5 py-1 rounded-full">{w.tag}</span>
        </a>
        <div class="p-5 flex flex-col flex-1">
          <h2 class="font-heading font-semibold text-ink text-lg group-hover:text-primary transition-colors">
            <a href={`/wisata/${w.slug}`}>{w.nama}</a>
          </h2>
          <p class="text-sm text-muted mt-1 flex-1 line-clamp-2">{excerpt(w.deskripsi_html, 100)}</p>
          <a href={`/wisata/${w.slug}`} class="inline-flex items-center gap-1.5 mt-4 text-accent font-heading font-semibold text-sm hover:underline">
            Jelajahi <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
      </article>
    ))}
  </div>
</main>

</Layout>

<script is:inline>
  setTimeout(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); }, 300);
</script>
