---
import '../styles/global.css';
import Nav from './Nav.astro';
import Footer from './Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  transparentNav?: boolean;
}

const {
  title,
  description = 'Situs resmi Pemerintah Desa Sindangsari, Kecamatan Kasomalang, Kabupaten Subang.',
  ogImage,
  transparentNav = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://sindangsarikasomalang.web.id').href;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Lucide icons -->
    <script src="https://unpkg.com/lucide@latest" defer></script>
    <!-- Cloudflare Web Analytics -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "REPLACE_WITH_CF_ANALYTICS_TOKEN"}'></script>
  </head>

  <body class="bg-bg text-text font-body min-h-screen">

    <!-- Skip to main content (first focusable element) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:top-2 focus:left-2 focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded focus:outline-none"
    >
      Lewati ke konten utama
    </a>

    <!-- Navigation -->
    <Nav transparent={transparentNav} currentPath={currentPath} />

    <!-- Main content -->
    <main
      id="main-content"
      class={transparentNav ? '' : 'pt-20'}
    >
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

  </body>
</html>
