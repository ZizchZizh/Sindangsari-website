---
import Layout from '../components/Layout.astro';
import { getPublishedWisata } from '../lib/db/wisata';
import { getPublishedUmkm } from '../lib/db/umkm';
import { getPublishedBerita, formatTanggal, excerpt } from '../lib/db/berita';
import { getEnv } from '@lib/env';

const env = getEnv();

const [wisataList, umkmList, beritaList] = await Promise.all([
  env ? getPublishedWisata(env.DB) : [],
  env ? getPublishedUmkm(env.DB) : [],
  env ? getPublishedBerita(env.DB, 3) : [],
]);

const demoWisata = [
  { slug: 'curug-masigit', nama: 'Curug Masigit', img: '/images/curug_masigit.png', tag: 'Air Terjun', desc: 'Air terjun eksotis dengan air jernih berwarna hijau kebiruan, diapit tebing batu yang megah.' },
  { slug: 'ekowisata-alam-kasomalang', nama: 'Ekowisata Alam Kasomalang', img: '/images/ekowisata_kasomalang.png', tag: 'Alam', desc: 'Keindahan alam pegunungan dengan udara sejuk dan panorama perbukitan hijau.' },
  { slug: 'panorama-sindangsari', nama: 'Panorama Sindangsari', img: '/images/hero_sindangsari.png', tag: 'Panorama', desc: 'Pemandangan dataran tinggi yang memukau dengan sawah terasering dan perbukitan.' },
];

const demoUmkm: Array<{slug:string;nama:string;kategori:string;img:string;wa:string|null;desc:string}> = [
  { slug: 'kerupuk-opak-ranginang', nama: 'Kerupuk, Opak & Ranginang', kategori: 'Makanan Tradisional', img: '/images/kerupuk_tradisional.png', wa: '6281234567890', desc: 'Makanan ringan tradisional khas Sunda buatan ibu-ibu Desa Sindangsari.' },
  { slug: 'kopi-aren-kasomalang', nama: 'Kopi Aren Kasomalang', kategori: 'Kuliner', img: '/images/kopi_aren.png', wa: '6282345678901', desc: 'Kopi pilihan dataran tinggi disajikan dengan gula aren asli.' },
  { slug: 'keripik-bonggol-pisang', nama: 'Keripik Bonggol Pisang', kategori: 'Makanan Olahan', img: '/images/keripik_bonggol.png', wa: null, desc: 'Camilan unik dari bonggol pisang, inovasi produk lokal bernilai ekonomi tinggi.' },
  { slug: 'hasil-tani-sindangsari', nama: 'Hasil Tani Sindangsari', kategori: 'Hasil Tani', img: '/images/sawah_sindangsari.png', wa: null, desc: 'Padi, jagung, dan buah-buahan segar dari dataran tinggi Sindangsari.' },
];

const demoBerita = [
  { slug: 'gotong-royong-desa', judul: 'Gotong Royong Warga Sindangsari Bersihkan Jalan Desa', published_at: '2026-07-12', img: '/images/gotong_royong.png', ringkasan: 'Warga bersama Karang Taruna bergotong royong membersihkan jalan desa menjelang musim hujan.' },
  { slug: 'pelatihan-digital-umkm', judul: 'Pelatihan Digital Marketing untuk UMKM Desa', published_at: '2026-07-08', img: '/images/pelatihan_umkm.png', ringkasan: 'Sepuluh pelaku UMKM mengikuti pelatihan foto produk dan WhatsApp Business.' },
  { slug: 'peluncuran-situs-resmi', judul: 'Peluncuran Situs Resmi Desa Sindangsari', published_at: '2026-07-01', img: '/images/pelatihan_umkm.png', ringkasan: 'Desa Sindangsari kini punya kehadiran digital resmi yang dapat diakses siapa saja.' },
];

const getWisataImg = (slug: string) => {
  if (slug === 'curug-masigit') return '/images/curug_masigit.png';
  if (slug === 'ekowisata-alam-kasomalang') return '/images/ekowisata_kasomalang.png';
  return '/images/hero_sindangsari.png';
};

const getUmkmImg = (slug: string) => {
  if (slug === 'kerupuk-opak-ranginang') return '/images/kerupuk_tradisional.png';
  if (slug === 'kopi-aren-kasomalang') return '/images/kopi_aren.png';
  if (slug === 'keripik-bonggol-pisang') return '/images/keripik_bonggol.png';
  return '/images/kerupuk_tradisional.png';
};

const finalWisata = wisataList.length > 0
  ? wisataList.slice(0, 3).map(w => ({ slug: w.slug, nama: w.nama, img: getWisataImg(w.slug), tag: 'Wisata', desc: excerpt(w.deskripsi_html, 100) }))
  : demoWisata;

const finalUmkm = umkmList.length > 0
  ? umkmList.slice(0, 4).map(u => ({ slug: u.slug, nama: u.nama, kategori: u.kategori, img: getUmkmImg(u.slug), wa: u.wa_number ?? null, desc: u.deskripsi_html ? excerpt(u.deskripsi_html, 80) : '' }))
  : demoUmkm;

const finalBerita = beritaList.length > 0
  ? beritaList.map(b => ({ slug: b.slug, judul: b.judul, published_at: b.published_at ?? '', img: '/images/gotong_royong.png', ringkasan: excerpt(b.content_html, 120) }))
  : demoBerita;
---

<Layout
  title="Desa Sindangsari — Desa Asri di Dataran Tinggi Subang"
  description="Situs resmi Pemerintah Desa Sindangsari, Kecamatan Kasomalang, Kabupaten Subang. Jelajahi ekowisata, UMKM lokal, dan potensi desa dataran tinggi yang asri."
  transparentNav={true}
>

<!-- ── Hero ──────────────────────────────────────────────────── -->
<section
  class="relative overflow-hidden"
  style="min-height: 78vh;"
  aria-labelledby="hero-heading"
>
  <!-- Background photo -->
  <div
    class="absolute inset-0 bg-cover bg-center"
    style="background-image: url('/images/hero_sindangsari.png');"
    role="img"
    aria-label="Panorama Desa Sindangsari, Kasomalang, Subang"
  ></div>
  <!-- Gradient overlay -->
  <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(20,83,45,0.55) 0%, rgba(20,83,45,0.35) 45%, rgba(20,83,45,0.75) 100%);"></div>

  <!-- Content -->
  <div class="relative mx-auto max-w-[1152px] px-4 sm:px-6 flex flex-col justify-end" style="min-height: 78vh; padding-bottom: 6rem;">
    <span class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm text-white text-xs font-heading font-semibold px-3 py-1 rounded-full w-max mb-4">
      <i data-lucide="map-pin" class="w-3.5 h-3.5"></i>
      Dataran Tinggi Kasomalang, Subang
    </span>
    <h1 id="hero-heading" class="font-heading font-extrabold text-white text-4xl sm:text-5xl lg:text-6xl leading-tight max-w-2xl">
      Jelajahi<br/>Desa Sindangsari
    </h1>
    <p class="text-white/85 text-lg mt-3 max-w-xl">
      Desa asri di dataran tinggi Subang — ekowisata alam, kearifan Sunda, dan UMKM lokal yang hidup.
    </p>
    <div class="flex flex-wrap gap-3 mt-6">
      <a href="/wisata" class="inline-flex items-center gap-2 bg-accent hover:bg-[#047857] text-white font-heading font-semibold px-5 py-3 rounded-lg transition-colors min-h-[44px]">
        <i data-lucide="compass" class="w-5 h-5"></i> Mulai Jelajahi
      </a>
      <a href="/peta" class="inline-flex items-center gap-2 bg-white/15 hover:bg-white/25 backdrop-blur text-white font-heading font-semibold px-5 py-3 rounded-lg transition-colors border border-white/30 min-h-[44px]">
        <i data-lucide="map" class="w-5 h-5"></i> Lihat Peta
      </a>
    </div>
  </div>
</section>

<!-- ── Discovery Tiles (image overlay, matching beranda-v2 mockup) ── -->
<section class="relative z-20 -mt-16 sm:-mt-20">
  <div class="mx-auto max-w-[1152px] px-4 sm:px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      {[
        { href: '/wisata', label: 'Wisata', img: '/images/tile_wisata.png' },
        { href: '/umkm', label: 'UMKM', img: '/images/tile_umkm.png' },
        { href: '/peta', label: 'Peta Desa', img: '/images/tile_peta.png' },
        { href: '/berita', label: 'Berita', img: '/images/tile_berita.png' },
      ].map(tile => (
        <a
          href={tile.href}
          class="tile group relative block rounded-2xl overflow-hidden h-44 sm:h-56 shadow-[0_4px_10px_rgba(16,35,26,.08)] hover:shadow-[0_16px_32px_rgba(16,35,26,.16)] transition-shadow"
        >
          <img
            src={tile.img}
            alt={tile.label}
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#14532D]/90 to-[#14532D]/10 opacity-70 group-hover:opacity-85 transition-opacity duration-200"></div>
          <div class="absolute inset-x-0 bottom-0 p-4 sm:p-5 flex items-center justify-between text-white">
            <span class="font-heading font-bold text-lg sm:text-xl">{tile.label}</span>
            <i data-lucide="arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-200"></i>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ── Selamat Datang (editorial intro, centered) ──────────────── -->
<section class="mx-auto max-w-[1152px] px-4 sm:px-6 pt-16 pb-6 text-center" aria-labelledby="welcome-heading">
  <span class="text-accent font-heading font-semibold">Selamat Datang</span>
  <h2 id="welcome-heading" class="text-3xl sm:text-4xl font-heading font-extrabold text-primary mt-2 max-w-2xl mx-auto leading-tight">
    Desa dataran tinggi yang asri, subur, dan kaya budaya Sunda
  </h2>
  <p class="text-muted text-lg mt-4 max-w-2xl mx-auto">
    Terletak di Kecamatan Kasomalang, Kabupaten Subang, Desa Sindangsari menawarkan keindahan alam pegunungan, pertanian yang subur, dan kearifan lokal yang mempesona.
  </p>
</section>

<!-- ── Hal yang Bisa Dilakukan (1 big + 2 small cards) ──────────── -->
<section class="py-10 pb-16" style="background-color: #F8FAFC;" aria-labelledby="aktivitas-heading">
  <div class="mx-auto max-w-[1152px] px-4 sm:px-6">
    <div class="flex items-end justify-between mb-6">
      <h2 id="aktivitas-heading" class="font-heading font-extrabold text-2xl sm:text-3xl text-primary">Hal yang Bisa Dilakukan</h2>
      <a href="/wisata" class="hidden sm:inline-flex items-center gap-1.5 text-primary font-heading font-semibold hover:underline">
        Semua wisata <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
    <div class="grid lg:grid-cols-2 gap-6">
      <!-- Big card (left) -->
      <a href={`/wisata/${finalWisata[0]?.slug ?? 'curug-masigit'}`}
         class="group relative block rounded-2xl overflow-hidden h-80 lg:h-full min-h-[20rem] shadow-[0_4px_10px_rgba(16,35,26,.08)] hover:shadow-[0_16px_32px_rgba(16,35,26,.16)] transition-shadow">
        <img
          src={finalWisata[0]?.img || '/images/curug_masigit.png'}
          alt={finalWisata[0]?.nama ?? 'Curug Masigit'}
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#14532D]/90 to-transparent"></div>
        <div class="absolute bottom-0 p-6 text-white">
          <span class="text-[13px] font-heading font-semibold px-2.5 py-1 rounded-full bg-accent/90">{finalWisata[0]?.tag ?? 'Air Terjun'}</span>
          <h3 class="font-heading font-bold text-2xl mt-2">{finalWisata[0]?.nama ?? 'Curug Masigit'}</h3>
          <p class="text-white/85 mt-1 max-w-md">{finalWisata[0]?.desc ?? 'Air terjun eksotis di Kasomalang dengan air jernih hijau kebiruan dan tebing batu megah.'}</p>
        </div>
      </a>
      <!-- Two small cards (right) -->
      <div class="grid sm:grid-cols-2 gap-6">
        <a href={`/wisata/${finalWisata[1]?.slug ?? 'ekowisata-alam-kasomalang'}`}
           class="group block bg-white border border-line rounded-2xl overflow-hidden shadow-[0_4px_10px_rgba(16,35,26,.08)] hover:shadow-[0_16px_32px_rgba(16,35,26,.16)] hover:border-accent transition-all">
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={finalWisata[1]?.img || '/images/ekowisata_kasomalang.png'}
              alt={finalWisata[1]?.nama ?? 'Ekowisata Alam Kasomalang'}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-5">
            <span class="text-[13px] font-heading font-semibold px-2.5 py-1 rounded-full bg-[#D1FAE5] text-[#047857]">{finalWisata[1]?.tag ?? 'Alam'}</span>
            <h3 class="font-heading font-bold text-lg text-ink mt-2 group-hover:text-primary transition-colors">{finalWisata[1]?.nama ?? 'Ekowisata Alam Kasomalang'}</h3>
            <p class="text-sm text-muted mt-1">{finalWisata[1]?.desc ?? 'Keindahan alam pegunungan yang asri dan menenangkan.'}</p>
          </div>
        </a>
        <a href={`/wisata/${finalWisata[2]?.slug ?? 'panorama-sindangsari'}`}
           class="group block bg-white border border-line rounded-2xl overflow-hidden shadow-[0_4px_10px_rgba(16,35,26,.08)] hover:shadow-[0_16px_32px_rgba(16,35,26,.16)] hover:border-accent transition-all">
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={finalWisata[2]?.img || '/images/hero_sindangsari.png'}
              alt={finalWisata[2]?.nama ?? 'Panorama Sindangsari'}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-5">
            <span class="text-[13px] font-heading font-semibold px-2.5 py-1 rounded-full bg-[#D1FAE5] text-[#047857]">{finalWisata[2]?.tag ?? 'Panorama'}</span>
            <h3 class="font-heading font-bold text-lg text-ink mt-2 group-hover:text-primary transition-colors">{finalWisata[2]?.nama ?? 'Panorama Sindangsari'}</h3>
            <p class="text-sm text-muted mt-1">{finalWisata[2]?.desc ?? 'Pemandangan dataran tinggi yang memukau.'}</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ── UMKM Band ────────────────────────────────────────────── -->
<section class="py-12 md:py-16" style="background-color: #14532D;" aria-labelledby="umkm-heading">
  <div class="mx-auto max-w-[1152px] px-4 sm:px-6">
    <div class="flex items-end justify-between mb-6">
      <div>
        <span class="text-[13px] font-heading font-semibold text-accent uppercase tracking-widest">Produk Lokal</span>
        <h2 id="umkm-heading" class="font-heading font-extrabold text-2xl sm:text-3xl text-white mt-1">UMKM Unggulan</h2>
      </div>
      <a href="/umkm" class="text-sm font-heading font-semibold text-accent hover:text-white flex items-center gap-1 transition-colors">
        Lihat Semua <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {finalUmkm.map(u => (
        <article class="bg-white/10 backdrop-blur rounded-2xl overflow-hidden border border-white/10 flex flex-col">
          <a href={`/umkm/${u.slug}`} class="block aspect-[16/10] overflow-hidden relative">
            {u.img ? (
              <img
                src={u.img}
                alt={u.nama}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full" style="background: linear-gradient(135deg, #059669, #15803D);"></div>
            )}
          </a>
          <div class="p-4 flex flex-col flex-1">
            <span class="text-xs font-heading font-semibold text-accent">{u.kategori}</span>
            <h3 class="font-heading font-semibold text-white mt-1"><a href={`/umkm/${u.slug}`} class="hover:text-accent transition-colors">{u.nama}</a></h3>
            <p class="text-white/60 text-sm mt-1 flex-1 line-clamp-2">{u.desc}</p>
            {u.wa ? (
              <a href={`https://wa.me/${u.wa}`} target="_blank" rel="noopener noreferrer"
                 class="mt-3 inline-flex items-center justify-center gap-2 bg-cta hover:bg-ctaDark text-white text-sm font-heading font-semibold py-2.5 rounded-lg transition-colors min-h-[44px]">
                <i data-lucide="message-circle" class="w-4 h-4"></i> WhatsApp
              </a>
            ) : (
              <a href={`/umkm/${u.slug}`}
                 class="mt-3 inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white text-sm font-heading font-semibold py-2.5 rounded-lg hover:border-white/60 transition-colors min-h-[44px]">
                Lihat Detail
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ── Peta Feature ─────────────────────────────────────────── -->
<section class="relative py-16 md:py-24 overflow-hidden" aria-labelledby="peta-heading">
  <!-- Background -->
  <div class="absolute inset-0">
    <img
      src="/images/hero_sindangsari.png"
      alt=""
      class="w-full h-full object-cover"
      aria-hidden="true"
      loading="lazy"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(20,83,45,0.92) 0%, rgba(20,83,45,0.75) 60%, rgba(20,83,45,0.5) 100%);"></div>
  </div>
  <div class="relative mx-auto max-w-[1152px] px-4 sm:px-6">
    <div class="max-w-xl text-white">
      <span class="text-[13px] font-heading font-semibold text-accent uppercase tracking-widest">Peta Desa</span>
      <h2 id="peta-heading" class="font-heading font-extrabold text-3xl sm:text-4xl mt-2">Temukan Semua yang Ada di Sindangsari</h2>
      <p class="text-white/80 mt-3 leading-relaxed">
        Jelajahi peta interaktif Desa Sindangsari — titik wisata, UMKM, dan potensi alam ditandai langsung di peta. Klik penanda untuk detail dan rute.
      </p>
      <div class="flex flex-wrap gap-4 mt-6">
        {[
          { icon: 'palmtree', label: '6 Wisata', color: '#2DD4BF' },
          { icon: 'store', label: '12 UMKM', color: '#4ADE80' },
          { icon: 'sprout', label: '3 Potensi', color: '#F4EBDD' },
        ].map(item => (
          <span class="flex items-center gap-2 text-sm text-white/80">
            <i data-lucide={item.icon} class="w-4 h-4" style={`color:${item.color}`}></i>
            {item.label}
          </span>
        ))}
      </div>
      <a href="/peta" class="inline-flex items-center gap-2 mt-6 bg-accent hover:bg-[#047857] text-white font-heading font-semibold px-5 py-3 rounded-lg transition-colors min-h-[44px]">
        <i data-lucide="map" class="w-5 h-5"></i> Buka Peta Interaktif
      </a>
    </div>
  </div>
</section>

<!-- ── Berita Terbaru ───────────────────────────────────────── -->
<section class="py-12 md:py-16" style="background-color: #F8FAFC;" aria-labelledby="berita-heading">
  <div class="mx-auto max-w-[1152px] px-4 sm:px-6">
    <div class="flex items-end justify-between mb-6">
      <div>
        <span class="text-[13px] font-heading font-semibold text-accent uppercase tracking-widest">Informasi</span>
        <h2 id="berita-heading" class="font-heading font-extrabold text-2xl sm:text-3xl text-ink mt-1">Berita & Pengumuman</h2>
      </div>
      <a href="/berita" class="text-sm font-heading font-semibold text-accent hover:underline flex items-center gap-1">
        Semua Berita <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {finalBerita.map(b => (
        <a href={`/berita/${b.slug}`} class="group block bg-white border border-line rounded-2xl overflow-hidden shadow-[0_4px_10px_rgba(16,35,26,.08)] hover:shadow-[0_12px_24px_rgba(16,35,26,.12)] hover:border-accent transition-all">
          <div class="aspect-[16/9] overflow-hidden">
            {b.img ? (
              <img
                src={b.img}
                alt={b.judul}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full" style="background: linear-gradient(135deg, #166534 0%, #059669 60%, #34D399 100%);"></div>
            )}
          </div>
          <div class="p-5">
            <time class="text-xs font-heading font-semibold text-muted">
              {b.published_at ? formatTanggal(b.published_at) : ''}
            </time>
            <h3 class="font-heading font-semibold text-ink mt-1 group-hover:text-primary transition-colors leading-snug">{b.judul}</h3>
            <p class="text-sm text-muted mt-1 line-clamp-2">{b.ringkasan}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof lucide !== 'undefined') lucide.createIcons();
  });
  document.addEventListener('lucide:ready', function() {
    lucide.createIcons();
  });
  setTimeout(function() {
    if (typeof lucide !== 'undefined') lucide.createIcons();
  }, 300);
</script>
