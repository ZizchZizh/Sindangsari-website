---
import AdminLayout from '../../../components/AdminLayout.astro';
import { getSection } from '../../../lib/db/page-section';

const { slug } = Astro.params as { slug: string };
import { getEnv } from '@lib/env';
const env = getEnv();

const section = env ? await getSection(slug, env.DB) : null;
if (!section) return Astro.redirect('/admin/konten');

const saved = Astro.url.searchParams.get('saved');
const sectionLabel = slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
---

<AdminLayout title={`Edit: ${sectionLabel}`} breadcrumb={`Konten / ${sectionLabel}`}>

  {saved && (
    <div role="status" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#D1FAE5; color:#065F46; border:1px solid #6EE7B7;">
      Konten berhasil disimpan.
    </div>
  )}

  <div class="max-w-3xl">
    <h2 class="font-heading font-bold text-xl mb-6" style="color:var(--color-primary);">{sectionLabel}</h2>

    <form method="POST" action="/api/admin/konten" class="space-y-5">
      <input type="hidden" name="slug" value={slug} />

      <div>
        <label for="title" class="block font-heading font-medium text-sm mb-1.5">
          Judul <span>*</span> <span class="font-normal text-text-muted">(wajib)</span>
        </label>
        <input
          type="text" id="title" name="title" required
          value={section.title}
          class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border); min-height:44px;"
        />
      </div>

      <div>
        <label for="content_html" class="block font-heading font-medium text-sm mb-1.5">
          Konten
        </label>
        <!-- Simple rich text toolbar -->
        <div class="border rounded-t-lg px-2 py-1.5 flex gap-1 flex-wrap" style="border-color:var(--color-border); background:#F8FAFC;">
          {['Bold', 'Italic', 'Underline'].map(cmd => (
            <button type="button" data-cmd={cmd.toLowerCase()}
              class="px-2 py-1 text-xs font-heading font-semibold rounded hover:bg-sand transition-colors cursor-pointer border border-border"
              title={cmd} aria-label={cmd}>
              {cmd === 'Bold' ? 'B' : cmd === 'Italic' ? 'I' : 'U'}
            </button>
          ))}
          <span class="w-px bg-border mx-1"></span>
          {[['insertUnorderedList','Daftar •'],['insertOrderedList','Daftar 1.'],['formatBlock-h2','Sub-judul']].map(([cmd, label]) => (
            <button type="button" data-cmd={cmd}
              class="px-2 py-1 text-xs font-heading rounded hover:bg-sand transition-colors cursor-pointer border border-border">
              {label}
            </button>
          ))}
        </div>
        <div
          id="editor"
          contenteditable="true"
          class="w-full min-h-48 border border-t-0 rounded-b-lg px-4 py-3 text-base focus:outline-none prose max-w-none"
          style="border-color:var(--color-border);"
          set:html={section.content_html}
        ></div>
        <input type="hidden" id="content_html" name="content_html" value={section.content_html} />
      </div>

      <!-- Sticky action bar -->
      <div class="sticky bottom-0 bg-white border-t border-border -mx-4 md:-mx-6 px-4 md:px-6 py-3 flex justify-end gap-3" style="box-shadow:0 -2px 8px rgba(0,0,0,.06);">
        <a href="/admin/konten"
          class="px-4 py-2 rounded-lg font-heading font-medium text-sm border transition-colors hover:bg-sand cursor-pointer focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
          style="border-color:var(--color-border); min-height:44px; display:flex; align-items:center;">
          Batal
        </a>
        <button type="submit"
          class="px-5 py-2 rounded-lg font-heading font-semibold text-white text-sm cursor-pointer focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
          style="background:var(--color-cta); min-height:44px;">
          Simpan
        </button>
      </div>
    </form>
  </div>

</AdminLayout>

<style>
  #editor h2 { font-size:1.25rem; font-weight:700; margin:1rem 0 .5rem; }
  #editor ul { list-style:disc; padding-left:1.5rem; }
  #editor ol { list-style:decimal; padding-left:1.5rem; }
  #editor p { margin:.25rem 0; }
</style>

<script>
  const editor = document.getElementById('editor') as HTMLDivElement;
  const hidden = document.getElementById('content_html') as HTMLInputElement;

  // PENTING: JANGAN pakai document.querySelector('form') di sini.
  // AdminLayout merender form Logout di sidebar, dan sidebar berada SEBELUM
  // konten di DOM — jadi querySelector('form') mengambil form Logout, bukan
  // form ini. Akibatnya isi editor tidak pernah tersalin ke hidden input:
  // halaman Tambah menyimpan deskripsi KOSONG, halaman Sunting menyimpan teks
  // LAMA. Ikat selalu ke form yang memuat editornya sendiri.
  hidden.closest('form')?.addEventListener('submit', () => {
    hidden.value = editor.innerHTML;
  });

  // Toolbar commands
  document.querySelectorAll('[data-cmd]').forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = (btn as HTMLElement).dataset.cmd ?? '';
      editor.focus();
      if (cmd.startsWith('formatBlock-')) {
        document.execCommand('formatBlock', false, cmd.split('-')[1]);
      } else {
        document.execCommand(cmd, false);
      }
    });
  });
</script>
